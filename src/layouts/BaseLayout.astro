          <li>
            <a href="/wallet" class="nav__link nav__link--icon">
              <svg class="nav__link-icon" viewBox="0 0 24 24" fill="none" width="16" height="16" aria-hidden="true">
                <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
                <path d="M2 11h20" stroke="currentColor" stroke-width="1.5" opacity="0.35"/>
                <path d="M7 4l1.5-1h7L17 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5"/>
                <rect x="14.5" y="13.5" width="5" height="4" rx="1" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.25"/>
                <circle cx="17" cy="15.5" r="1" fill="currentColor" opacity="0.7"/>
              </svg>
              내 지갑
            </a>
          </li>
          <li>
            <a href="/portfolio" class="nav__link nav__link--icon">
              <svg class="nav__link-icon" viewBox="0 0 24 24" fill="none" width="16" height="16" aria-hidden="true">
                <rect x="2" y="7" width="20" height="15" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
                <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <path d="M2 12h20" stroke="currentColor" stroke-width="1.5" opacity="0.35"/>
              </svg>
              포트폴리오
            </a>
          </li>
          <li><a href="/economy/basics" class="nav__link">기초 경제학</a></li>
          <li><a href="/economy/investment" class="nav__link">투자 기초</a></li>
          <li><a href="/economy/finance" class="nav__link">생활 금융</a></li>
          <li><a href="/economy/global" class="nav__link">글로벌 경제</a></li>
        </ul>
        <div class="nav__actions" style="display: flex; align-items: center; gap: 12px;">
          <button id="theme-toggle" class="nav__theme-btn" aria-label="테마 변경">
            <svg class="icon-svg sun-icon" viewBox="0 0 24 24"><path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 000-1.41l-1.06-1.06zm1.06-12.37a.996.996 0 00-1.41 0l-1.06 1.06a.996.996 0 101.41 1.41l1.06-1.06a.996.996 0 000-1.41zm-12.37 12.37l-1.06 1.06a.996.996 0 101.41 1.41l1.06-1.06a.996.996 0 000-1.41z"/></svg>
            <svg class="icon-svg moon-icon" viewBox="0 0 24 24" style="display: none;"><path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-3.03 0-5.5-2.47-5.5-5.5 0-1.82.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/></svg>
          </button>
          <button class="nav__search" id="search-trigger">
            <svg class="icon-svg" viewBox="0 0 24 24" style="font-size: 1.1em;"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            검색 <kbd>⌘K</kbd>
