---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  article?: boolean;
}

const { title, description, ogImage = '/og-default.png', article = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO Meta -->
    <title>{title} | EconPedia</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={`${title} | EconPedia`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="EconPedia — 경제 백과사전" />
    <meta property="og:locale" content="ko_KR" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | EconPedia`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": article ? "Article" : "WebSite",
      "name": `${title} | EconPedia`,
      "description": description,
      "url": canonicalURL.toString(),
      ...(article ? {} : {
        "potentialAction": {
          "@type": "SearchAction",
          "target": `${Astro.site}search?q={search_term_string}`,
          "query-input": "required name=search_term_string"
        }
      })
    })} />
    
    <!-- Styles -->
    <style is:global>
      @import '../styles/global.css';
    </style>

    <!-- Visit Tracker -->
    <script is:inline>
      // 페이지 로드 시 한 번만 방문자 카운트 올리기 (간단한 세션 스토리지 체크로 중복 방지)
      if (!sessionStorage.getItem('visited')) {
        fetch('/api/track').catch(() => {});
        sessionStorage.setItem('visited', '1');
      }
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8793696080407617" crossorigin="anonymous"></script>
  </head>
  <body>
    <!-- Reading Progress Bar -->
    <div class="reading-progress-container" aria-hidden="true">
      <div id="reading-progress-bar" class="reading-progress-bar"></div>
    </div>

    <!-- Navigation -->
    <nav class="nav" id="main-nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo">
          <svg class="icon-svg icon-svg--lg icon-svg--accent" viewBox="0 0 24 24">
            <!-- 차트 위로 돋아난 새싹 아이콘 -->
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" opacity="0.3"/>
            <path d="M12 14c0-2.21 1.79-4 4-4s4 1.79 4 4v4h-8v-4z" fill="var(--color-accent-secondary)"/>
            <path d="M13 10c0-1.1.9-2 2-2s2 .9 2 2" fill="none" stroke="var(--color-accent-secondary)" stroke-width="2" stroke-linecap="round"/>
          </svg>
          EconPedia
        </a>
        <ul class="nav__links">
          <li>
            <a href="/daily" class="nav__link nav__link--live">
              <span class="pulse-dot pulse-dot--sm" style="background-color: var(--color-accent-secondary); box-shadow: 0 0 0 rgba(132, 204, 22, 0.4);"></span>
              데일리 브리핑
            </a>
          </li>
          <li><a href="/economy/basics" class="nav__link">기초 경제학</a></li>
          <li><a href="/economy/investment" class="nav__link">투자 기초</a></li>
          <li><a href="/economy/finance" class="nav__link">생활 금융</a></li>
          <li><a href="/economy/global" class="nav__link">글로벌 경제</a></li>
        </ul>
        <button class="nav__search hover-lift" id="search-trigger">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
          검색 <kbd>⌘K</kbd>
        </button>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Search Modal -->
    <div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="검색">
      <div class="search-modal__backdrop" id="search-backdrop"></div>
      <div class="search-modal__box">
        <div class="search-modal__header">
          <svg class="search-modal__icon icon-svg icon-svg--accent" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
          <input
            type="text"
            id="search-input"
            class="search-modal__input"
            placeholder="기사 검색... (예: GDP, 금리, ETF)"
            autocomplete="off"
            spellcheck="false"
          />
          <button class="search-modal__close" id="search-close" aria-label="닫기">✕</button>
        </div>
        <div id="search-results" class="search-modal__results" role="listbox">
          <div class="search-modal__empty" id="search-hint">
            <svg class="icon-svg icon-svg--xl icon-svg--accent" viewBox="0 0 24 24" style="margin-bottom: 1rem; opacity: 0.5;"><path d="M20 2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM9 19H7v-2h2v2zm0-4H7v-2h2v2zm0-4H7V9h2v2zm4 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm4 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2z"/></svg>
            <p>검색어를 입력하세요</p>
            <div class="search-modal__shortcuts">
              <kbd>↑</kbd><kbd>↓</kbd> 이동 &nbsp; <kbd>Enter</kbd> 선택 &nbsp; <kbd>ESC</kbd> 닫기
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 통합 구독 허브 (텔레그램 + 뉴스레터) -->
    <section class="sub-hub">
      <div class="sub-hub__inner">
        <!-- 왼쪽: 텔레그램 (실시간 알림) -->
        <div class="sub-card sub-card--telegram hover-lift" style="background: linear-gradient(145deg, #064e3b 0%, #022c22 150%); border-color: rgba(16, 185, 129, 0.2);">
          <div class="sub-card__badge" style="color: var(--color-text-secondary);">
            <svg class="icon-svg" viewBox="0 0 24 24" style="margin-right: 4px; font-size: 0.9em;"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.13-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .24z"/></svg>
            실시간 알림
          </div>
          <h2 class="sub-card__title">텔레그램 채널</h2>
          <p class="sub-card__desc">오늘의 시장 변동과 카드뉴스를<br/>가장 빠르게 확인하세요.</p>
          <a href="https://t.me/econpedia_channel" target="_blank" rel="noopener noreferrer" class="sub-card__btn shimmer-effect" style="background: var(--color-accent-primary); color: white;">
            채널 입장하기
          </a>
        </div>

        <!-- 오른쪽: 뉴스레터 (매일 아침 브리핑) -->
        <div class="sub-card sub-card--newsletter hover-lift" style="background: linear-gradient(145deg, #065f46 0%, #059669 150%); border-color: rgba(132, 204, 22, 0.2);">
          <div class="sub-card__badge" style="color: var(--color-accent-secondary);">
            <svg class="icon-svg" viewBox="0 0 24 24" style="margin-right: 4px; font-size: 0.9em;"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            무료 뉴스레터
          </div>
          <h2 class="sub-card__title">데일리 브리핑</h2>
          <p class="sub-card__desc">매일 오전 7시, AI가 분석한<br/>경제 핵심을 메일로 보내드려요.</p>
          <form class="sub-form" id="subscribe-form">
            <input
              type="email"
              id="subscribe-email"
              class="sub-form__input"
              placeholder="your@email.com"
              required
            />
            <button type="submit" class="sub-form__btn shimmer-effect" id="subscribe-btn" style="background: var(--color-accent-secondary); color: white;">
              <span class="btn-text">구독하기</span>
              <span class="btn-loading" style="display:none">...</span>
            </button>
          </form>
          <div id="subscribe-feedback" class="sub-feedback" style="display:none"></div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer__inner">
        <div>
          <a href="/" class="nav__logo">
            <span class="nav__logo-icon">📊</span>
            EconPedia
          </a>
          <p class="footer__brand-desc">
            경제 초보자를 전문가로 만드는 경제 백과사전.<br/>
            복잡한 경제를 쉽고 재밌게 풀어드립니다.
          </p>
        </div>
        <div>
          <h4 class="footer__heading">카테고리</h4>
          <ul class="footer__links">
            <li><a href="/economy/basics">기초 경제학</a></li>
            <li><a href="/economy/investment">투자 기초</a></li>
            <li><a href="/economy/finance">생활 금융</a></li>
            <li><a href="/economy/global">글로벌 경제</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer__heading">더 보기</h4>
          <ul class="footer__links">
            <li><a href="/economy/indicators">경제 지표</a></li>
            <li><a href="/economy/corporate">기업 분석</a></li>
            <li><a href="/economy/trends">경제 트렌드</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer__heading">소개</h4>
          <ul class="footer__links">
            <li><a href="/about">EconPedia 소개</a></li>
            <li><a href="/contact">문의하기</a></li>
            <li><a href="/advertise">광고 문의</a></li>
          </ul>
        </div>
      </div>
      <div class="footer__bottom">
        <p>&copy; 2026 EconPedia. 경제를 쉽게, 모두에게.</p>
      </div>
    </footer>

    <!-- 읽기 진행률 스크립트 -->
    <script is:inline>
      (function() {
        const progressBar = document.getElementById('reading-progress-bar');
        if (!progressBar) return;

        let lastKnownScrollPosition = 0;
        let ticking = false;

        function updateProgress(scrollPos) {
          const winHeight = window.innerHeight;
          const docHeight = document.body.offsetHeight;
          const totalScroll = docHeight - winHeight;
          const progress = (scrollPos / totalScroll) * 100;
          
          progressBar.style.width = Math.min(Math.max(progress, 0), 100) + '%';
          ticking = false;
        }

        window.addEventListener('scroll', function() {
          lastKnownScrollPosition = window.scrollY;

          if (!ticking) {
            window.requestAnimationFrame(function() {
              updateProgress(lastKnownScrollPosition);
            });
            ticking = true;
          }
        }, { passive: true });
      })();
    </script>

    <!-- Fuse.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.min.js"></script>
    <script>
      (function () {
        const modal = document.getElementById('search-modal');
        const backdrop = document.getElementById('search-backdrop');
        const input = document.getElementById('search-input');
        const results = document.getElementById('search-results');
        const hint = document.getElementById('search-hint');
        const closebtn = document.getElementById('search-close');
        const trigger = document.getElementById('search-trigger');

        let fuse = null;
        let selectedIdx = -1;
        let items = [];

        // Open modal
        function openModal() {
          modal.classList.add('search-modal--open');
          setTimeout(() => input.focus(), 50);
          if (!fuse) loadData();
        }

        // Close modal
        function closeModal() {
          modal.classList.remove('search-modal--open');
          input.value = '';
          results.innerHTML = '';
          results.appendChild(hint);
          selectedIdx = -1;
        }

        // Load search data
        async function loadData() {
          try {
            const res = await fetch('/search-data.json');
            const data = await res.json();
            fuse = new Fuse(data, {
              keys: [
                { name: 'title', weight: 0.7 },
                { name: 'excerpt', weight: 0.3 },
                { name: 'category', weight: 0.1 },
              ],
              threshold: 0.4,
              includeMatches: true,
            });
          } catch (e) {
            console.error('Search data load failed', e);
          }
        }

        // Render results
        function renderResults(query) {
          if (!fuse || !query.trim()) {
            results.innerHTML = '';
            results.appendChild(hint);
            items = [];
            selectedIdx = -1;
            return;
          }

          const found = fuse.search(query).slice(0, 8);
          items = found.map(r => r.item);

          if (items.length === 0) {
            results.innerHTML = `
              <div class="search-modal__empty">
                <div class="search-modal__empty-icon">😔</div>
                <p>"${query}"에 대한 결과가 없습니다</p>
              </div>`;
            return;
          }

          results.innerHTML = items.map((item, i) => `
            <a href="${item.href}" class="search-result" role="option" data-idx="${i}" id="result-${i}">
              <div class="search-result__meta">
                <span class="search-result__icon">${item.icon}</span>
                <span class="search-result__category">${item.category}</span>
              </div>
              <div class="search-result__title">${item.title}</div>
              <div class="search-result__excerpt">${item.excerpt}</div>
            </a>
          `).join('');

          selectedIdx = -1;
        }

        // Keyboard navigation
        function updateSelection(newIdx) {
          const els = results.querySelectorAll('.search-result');
          els.forEach((el, i) => el.classList.toggle('search-result--active', i === newIdx));
          if (newIdx >= 0 && els[newIdx]) els[newIdx].scrollIntoView({ block: 'nearest' });
          selectedIdx = newIdx;
        }

        // Events
        trigger.addEventListener('click', openModal);
        backdrop.addEventListener('click', closeModal);
        closebtn.addEventListener('click', closeModal);

        input.addEventListener('input', (e) => renderResults(e.target.value));

        input.addEventListener('keydown', (e) => {
          const count = items.length;
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            updateSelection(Math.min(selectedIdx + 1, count - 1));
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            updateSelection(Math.max(selectedIdx - 1, 0));
          } else if (e.key === 'Enter') {
            if (selectedIdx >= 0 && items[selectedIdx]) {
              window.location.href = items[selectedIdx].href;
            }
          } else if (e.key === 'Escape') {
            closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.classList.contains('search-modal--open') ? closeModal() : openModal();
          }
          if (e.key === 'Escape' && modal.classList.contains('search-modal--open')) {
            closeModal();
          }
        });
      })();
    </script>

    <!-- 뉴스레터 구독 스크립트 -->
    <script>
      (function () {
        const form = document.getElementById('subscribe-form');
        if (!form) return;

        const emailInput = document.getElementById('subscribe-email');
        const btn = document.getElementById('subscribe-btn');
        const btnText = btn.querySelector('.subscribe-btn-text');
        const btnLoading = btn.querySelector('.subscribe-btn-loading');
        const feedback = document.getElementById('subscribe-feedback');

        function setLoading(on) {
          btn.disabled = on;
          btnText.style.display = on ? 'none' : '';
          btnLoading.style.display = on ? '' : 'none';
        }

        function showFeedback(message, isSuccess) {
          feedback.textContent = message;
          feedback.className = 'newsletter-feedback ' + (isSuccess ? 'newsletter-feedback--success' : 'newsletter-feedback--error');
          feedback.style.display = '';
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = emailInput.value.trim();
          if (!email) return;

          setLoading(true);
          feedback.style.display = 'none';

          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });
            const data = await res.json();

            if (res.ok && data.success) {
              showFeedback(data.message || '구독 신청이 완료됐습니다! 📊', true);
              emailInput.value = '';
              // 성공 시 버튼 텍스트 변경
              btnText.textContent = '✅ 구독 완료!';
              btnText.style.display = '';
              btnLoading.style.display = 'none';
              btn.disabled = true;
              btn.style.background = 'linear-gradient(135deg, #10b981, #059669)';
            } else {
              showFeedback(data.error || '오류가 발생했습니다. 다시 시도해주세요.', false);
              setLoading(false);
            }
          } catch (err) {
            showFeedback('네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.', false);
            setLoading(false);
          }
        });
      })();
    </script>
  </body>
</html>
