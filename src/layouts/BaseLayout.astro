---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  article?: boolean;
}

const { title, description, ogImage = '/og-default.png', article = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Theme Init (Prevent FOUC) -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
        } else {
          const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', systemDark ? 'dark' : 'light');
        }
      })();
    </script>

    <!-- SEO Meta -->
    <title>{title} | EconPedia</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={`${title} | EconPedia`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="EconPedia — 경제 백과사전" />
    <meta property="og:locale" content="ko_KR" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | EconPedia`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": article ? "Article" : "WebSite",
      "name": `${title} | EconPedia`,
      "description": description,
      "url": canonicalURL.toString(),
      ...(article ? {} : {
        "potentialAction": {
          "@type": "SearchAction",
          "target": `${Astro.site}search?q={search_term_string}`,
          "query-input": "required name=search_term_string"
        }
      })
    })} />
    
    <!-- Styles -->
    <style is:global>
      @import '../styles/global.css';
    </style>

    <!-- Visit Tracker -->
    <script is:inline>
      // 기존 단순 방문자 카운트
      if (!sessionStorage.getItem('visited')) {
        fetch('/api/track').catch(() => {});
        sessionStorage.setItem('visited', '1');
      }
    </script>

    <!-- Analytics Tracker (체류 시간 / 이탈률 자체 분석 로직) -->
    <script is:inline>
      (function() {
        try {
          const SESSION_KEY = 'ep_session_id';
          const PAGE_VIEW_KEY = 'ep_page_views';
          let sessionId = sessionStorage.getItem(SESSION_KEY);
          let isNewSession = false;
          
          if (!sessionId) {
            sessionId = 'sess_' + Math.random().toString(36).substr(2, 9);
            sessionStorage.setItem(SESSION_KEY, sessionId);
            sessionStorage.setItem(PAGE_VIEW_KEY, '1');
            isNewSession = true;
          } else {
            sessionStorage.setItem(PAGE_VIEW_KEY, parseInt(sessionStorage.getItem(PAGE_VIEW_KEY) || '1') + 1);
          }

          const pageViews = parseInt(sessionStorage.getItem(PAGE_VIEW_KEY));
          const isFirstPage = pageViews === 1;

          // 1. Pageview 기록
          fetch('/api/analytics', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'pageview', path: window.location.pathname, isNewSession })
          }).catch(() => {});

          let startTime = Date.now();
          let totalTimeSent = 0;

          // 2. 체류 시간 및 이탈률 전송 함수
          function sendAnalytics(isUnload = false) {
            const timeSpent = Math.floor((Date.now() - startTime) / 1000) - totalTimeSent;
            
            if (timeSpent > 0) {
              const dwellPayload = JSON.stringify({ type: 'dwell', timeSpent, path: window.location.pathname });
              
              if (isUnload && navigator.sendBeacon) {
                navigator.sendBeacon('/api/analytics', dwellPayload);
                
                // 10초 미만 체류 후 사이트를 떠나고, 조회한 페이지가 1개뿐이면 이탈(Bounce)로 간주
                if (isFirstPage && (timeSpent + totalTimeSent) < 10) {
                  navigator.sendBeacon('/api/analytics', JSON.stringify({ type: 'bounce', path: window.location.pathname }));
                }
              } else if (!isUnload) {
                fetch('/api/analytics', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: dwellPayload
                }).catch(() => {});
                totalTimeSent += timeSpent;
              }
            }
          }

          // 15초마다 주기적으로 체류 시간 동기화
          setInterval(() => {
            if (document.visibilityState === 'visible') {
              sendAnalytics();
            }
          }, 15000);

          // 탭 변경/종료 시 처리
          document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'hidden') {
              sendAnalytics(true);
            } else {
              startTime = Date.now();
              totalTimeSent = 0;
            }
          });
        } catch(e) {
          console.error('Analytics tracking error:', e);
        }
      })();
    </script>

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ECONPEDIA1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ECONPEDIA1');
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8793696080407617" crossorigin="anonymous"></script>
  </head>
  <body>
    <!-- Reading Progress Bar -->
    <div class="reading-progress-container" aria-hidden="true">
      <div id="reading-progress-bar" class="reading-progress-bar"></div>
    </div>

    <!-- Navigation -->
    <nav class="nav" id="main-nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo">
          <svg class="nav__logo-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="1"   y="16" width="5"  height="7"  rx="1.5" fill="currentColor" opacity="0.3"/>
            <rect x="9.5" y="10" width="5"  height="13" rx="1.5" fill="currentColor" opacity="0.65"/>
            <rect x="18"  y="4"  width="5"  height="19" rx="1.5" fill="currentColor"/>
            <path d="M3.5 16 Q12 3.5 20.5 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
          </svg>
          <span class="nav__logo-text">Econ<span class="nav__logo-text--sub">Pedia</span></span>
        </a>
        <ul class="nav__links">
          <li>
