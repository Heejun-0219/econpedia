---
export interface Props {
  title: string;
  description: string;
  category: string;
  categoryHref: string;
  readingTime: string;
  publishDate: string;
  author?: string;
  series?: { title: string; current: number; total: number; articles: { title: string; href: string }[] };
  relatedArticles?: { title: string; category: string; href: string }[];
}

const { 
  title, description, category, categoryHref,
  readingTime, publishDate, author = 'EconPedia 편집부',
  series, relatedArticles = []
} = Astro.props;

import BaseLayout from './BaseLayout.astro';
---

<BaseLayout title={title} description={description} article={true}>
  <article class="article-layout">
    <!-- Breadcrumb -->
    <nav class="article-breadcrumb" aria-label="breadcrumb">
      <a href="/">홈</a> → <a href={categoryHref}>{category}</a> → <span>{title}</span>
    </nav>

    <!-- Series Nav (if part of series) -->
    {series && (
      <div class="series-nav">
        <span class="series-nav__label">📚 시리즈</span>
        <span class="series-nav__title">{series.title} ({series.current}/{series.total})</span>
        <div class="series-nav__list">
          {series.articles.map((a, i) => (
            <a 
              href={a.href} 
              class={`series-nav__item ${i + 1 === series.current ? 'series-nav__item--active' : ''}`}
            >
              {i + 1}. {a.title}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Article Header -->
    <header class="article-header">
      <div class="editor-badge">
        <div class="editor-badge__avatar">
          <span class="editor-badge__icon">📊</span>
        </div>
        <div class="editor-badge__info">
          <div class="editor-badge__meta">
            <span class="editor-badge__role">수석 경제 에디터</span>
            <span class="editor-badge__name">이코노 (Econo)</span>
          </div>
          <p class="editor-badge__bio">“복잡한 경제를 당신의 언어로 쉽게 통역해 드립니다.”</p>
        </div>
        <div class="editor-badge__status">
          <span class="status-chip">✅ 팩트체크 완료</span>
          <span class="status-chip">🤖 AI + 전문검수</span>
        </div>
      </div>

      <a href={categoryHref} class="article-header__category">{category}</a>
      <h1 class="article-header__title">{title}</h1>
      <p class="article-header__subtitle">{description}</p>
      <div class="article-header__meta">
        <span>✍️ {author}</span>
        <span>📅 {publishDate}</span>
        <span>⏱ {readingTime} 읽기</span>
      </div>
    </header>

    <!-- Article Content -->
    <div class="article-content">
      <slot />
    </div>

    <!-- Related Articles (체류 시간 극대화) -->
    {relatedArticles.length > 0 && (
      <div class="related-articles">
        <h3 class="related-articles__title">📖 이 기사도 함께 읽어보세요</h3>
        <div class="related-articles__list">
          {relatedArticles.map((article) => (
            <a href={article.href} class="related-articles__item">
              <div>
                <span class="related-articles__item-category">{article.category}</span>
                <span class="related-articles__item-title">{article.title}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Series Next/Prev -->
    {series && series.current < series.total && (
      <a href={series.articles[series.current]?.href} class="series-next-btn">
        다음 기사 읽기: {series.articles[series.current]?.title} →
      </a>
    )}
  </article>
</BaseLayout>

<style>
  .article-breadcrumb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }
  .article-breadcrumb a {
    color: var(--color-text-muted);
  }
  .article-breadcrumb a:hover {
    color: var(--color-accent-primary);
  }
  .article-breadcrumb span {
    color: var(--color-text-secondary);
  }

  .article-header__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .series-nav {
    background: var(--color-bg-card);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  .series-nav__label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent-primary);
  }
  .series-nav__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }
  .series-nav__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .series-nav__item {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .series-nav__item:hover {
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
  }
  .series-nav__item--active {
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-accent-primary);
    font-weight: 600;
  }

  .series-next-btn {
    display: block;
    text-align: center;
    padding: var(--space-lg);
    background: var(--gradient-primary);
    border-radius: var(--radius-lg);
    color: white;
    font-weight: 600;
    font-size: var(--text-lg);
    text-decoration: none;
    margin-top: var(--space-2xl);
    transition: all var(--transition-base);
  }
  .series-next-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.3);
    color: white;
  }
  /* Editor Badge UI — 페르소나 강화 */
  .editor-badge {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-2xl);
    max-width: fit-content;
  }

  @media (max-width: 600px) {
    .editor-badge {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      max-width: 100%;
    }
  }

  .editor-badge__avatar {
    width: 48px;
    height: 48px;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);
  }

  .editor-badge__icon {
    font-size: 1.5rem;
  }

  .editor-badge__info {
    flex: 1;
  }

  .editor-badge__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: 2px;
  }

  .editor-badge__role {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .editor-badge__name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .editor-badge__bio {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    font-style: italic;
    margin: 0;
  }

  .editor-badge__status {
    display: flex;
    gap: var(--space-xs);
    margin-left: var(--space-lg);
  }

  @media (max-width: 600px) {
    .editor-badge__status {
      margin-left: 0;
      margin-top: 4px;
    }
  }

  .status-chip {
    padding: 4px 8px;
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-accent-success);
    font-size: 10px;
    font-weight: 700;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    border: 1px solid rgba(16, 185, 129, 0.1);
  }
</style>
