---
export interface Props {
  title: string;
  description: string;
  category: string;
  categoryHref: string;
  readingTime: string;
  publishDate: string;
  author?: string;
  series?: { title: string; current: number; total: number; articles: { title: string; href: string }[] };
  relatedArticles?: { title: string; category: string; href: string }[];
}

const { 
  title, description, category, categoryHref,
  readingTime, publishDate, author = 'EconPedia 편집부',
  series, relatedArticles = []
} = Astro.props;

import BaseLayout from './BaseLayout.astro';
---

<BaseLayout title={title} description={description} article={true}>
  <article class="article-layout">
    <!-- Breadcrumb -->
    <nav class="article-breadcrumb" aria-label="breadcrumb">
      <a href="/">홈</a> → <a href={categoryHref}>{category}</a> → <span>{title}</span>
    </nav>

    <!-- Series Nav (if part of series) -->
    {series && (
      <div class="series-nav">
        <span class="series-nav__label"><svg class="icon-svg" viewBox="0 0 24 24" style="margin-right: 4px; font-size: 0.8em;"><path d="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27-7.38 5.74zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16z"/></svg> 시리즈</span>
        <span class="series-nav__title">{series.title} ({series.current}/{series.total})</span>
        <div class="series-nav__list">
          {series.articles.map((a, i) => (
            <a 
              href={a.href} 
              class={`series-nav__item ${i + 1 === series.current ? 'series-nav__item--active' : ''}`}
            >
              {i + 1}. {a.title}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Article Header -->
    <header class="article-header">
      <div class="editor-badge">
        <div class="editor-badge__avatar">
          <span class="editor-badge__icon">📊</span>
        </div>
        <div class="editor-badge__info">
          <div class="editor-badge__meta">
            <span class="editor-badge__role">수석 경제 에디터</span>
            <span class="editor-badge__name">이코노 (Econo)</span>
          </div>
          <p class="editor-badge__bio">“복잡한 경제를 당신의 언어로 쉽게 통역해 드립니다.”</p>
        </div>
        <div class="editor-badge__status">
          <span class="status-chip">✅ 팩트체크 완료</span>
          <span class="status-chip">🤖 AI + 전문검수</span>
        </div>
      </div>

      <a href={categoryHref} class="article-header__category">{category}</a>
      <h1 class="article-header__title">{title}</h1>
      <p class="article-header__subtitle">{description}</p>
      <div class="article-header__meta">
        <span>✍️ {author}</span>
        <span>📅 {publishDate}</span>
        <span>⏱ {readingTime} 읽기</span>
      </div>
    </header>

    <!-- Article Content -->
    <div class="article-content">
      <slot />
    </div>

    <!-- Related Articles (체류 시간 극대화) -->
    {relatedArticles.length > 0 && (
      <div class="related-articles">
        <h3 class="related-articles__title">📖 이 기사도 함께 읽어보세요</h3>
        <div class="related-articles__list">
          {relatedArticles.map((article) => (
            <a href={article.href} class="related-articles__item">
              <div>
                <span class="related-articles__item-category">{article.category}</span>
                <span class="related-articles__item-title">{article.title}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Series Next/Prev -->
    {series && series.current < series.total && (
      <a href={series.articles[series.current]?.href} class="series-next-btn">
        다음 기사 읽기: {series.articles[series.current]?.title} →
      </a>
    )}
  </article>
</BaseLayout>

<style>
  .article-breadcrumb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }
  .article-breadcrumb a {
    color: var(--color-text-muted);
  }
  .article-breadcrumb a:hover {
    color: var(--color-accent-primary);
  }
  .article-breadcrumb span {
    color: var(--color-text-secondary);
  }

  .article-header__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .series-nav {
    background: var(--color-bg-card);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  .series-nav__label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent-primary);
  }
  .series-nav__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }
  .series-nav__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .series-nav__item {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .series-nav__item:hover {
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
  }
  .series-nav__item--active {
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-accent-primary);
    font-weight: 600;
  }

  .series-next-btn {
    display: block;
    text-align: center;
    padding: var(--space-lg);
    background: var(--gradient-primary);
    border-radius: var(--radius-lg);
    color: white;
    font-weight: 600;
    font-size: var(--text-lg);
    text-decoration: none;
    margin-top: var(--space-2xl);
    transition: all var(--transition-base);
  }
  .series-next-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.3);
    color: white;
  }
  /* Editor Badge UI — 라이트 모드 최적화 */
  .editor-badge {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: #f0fdf4; /* 맑은 민트 배경 */
    border: 1px solid rgba(22, 163, 74, 0.1);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-2xl);
    max-width: fit-content;
  }

  @media (max-width: 600px) {
    .editor-badge {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      max-width: 100%;
    }
  }

  .editor-badge__avatar {
    width: 48px;
    height: 48px;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.2);
  }

  .editor-badge__icon {
    font-size: 1.5rem;
    color: white;
  }

  .editor-badge__info {
    flex: 1;
  }

  .editor-badge__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: 2px;
  }

  .editor-badge__role {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .editor-badge__name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: #0f172a;
  }

  .editor-badge__bio {
    font-size: var(--text-xs);
    color: #475569;
    font-style: italic;
    margin: 0;
  }

  .editor-badge__status {
    display: flex;
    gap: var(--space-xs);
    margin-left: var(--space-lg);
  }

  @media (max-width: 600px) {
    .editor-badge__status {
      margin-left: 0;
      margin-top: 4px;
    }
  }

  .status-chip {
    padding: 4px 8px;
    background: white;
    color: #16a34a;
    font-size: 10px;
    font-weight: 700;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    border: 1px solid rgba(22, 163, 74, 0.2);
  }

  /* Jargon Translator Styles */
  .jargon-term {
    cursor: help;
    border-bottom: 2px dotted #94a3b8;
    position: relative;
    transition: all 0.2s ease;
    color: inherit;
    font-weight: 600;
  }
  .jargon-term:hover {
    border-bottom-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
    background: rgba(22, 163, 74, 0.05);
  }

  .jargon-tooltip {
    display: none;
    position: absolute;
    z-index: 9999;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    width: max-content;
    max-width: 320px;
    padding: 16px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .jargon-tooltip.show {
    opacity: 1;
    transform: translateY(0);
  }
  
  .jargon-tooltip__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 8px;
  }
  .jargon-tooltip__title {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--color-accent-primary);
  }
  .jargon-tooltip__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0;
  }
  .jargon-tooltip__body {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-text);
  }
  .jargon-tooltip__body strong {
    color: #f59e0b; /* 토스식 경고/강조 오렌지 */
  }

  /* 모바일 바텀시트 스타일 */
  .jargon-tooltip--mobile {
    position: fixed;
    width: 100%;
    max-width: 100%;
    border-radius: 20px 20px 0 0;
    border: none;
    box-shadow: 0 -10px 40px rgba(0,0,0,0.2);
    padding: 24px;
    padding-bottom: env(safe-area-inset-bottom, 24px);
    transform: translateY(100%);
  }
  .jargon-tooltip--mobile.show {
    transform: translateY(0);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async function() {
    var articleBody = document.getElementById('article-body-content');
    if (!articleBody) return;

    try {
      var res = await fetch('/dictionary.json');
      if (!res.ok) return;
      var dictionary = await res.json();
      var terms = Object.keys(dictionary);
      if (terms.length === 0) return;

      var walker = document.createTreeWalker(articleBody, NodeFilter.SHOW_TEXT, null, false);
      var nodesToReplace = [];
      var node;
      while (node = walker.nextNode()) {
        if (node.parentElement && ['A', 'CODE', 'PRE', 'H1', 'H2', 'H3', 'BUTTON'].includes(node.parentElement.tagName)) continue;
        var text = node.nodeValue;
        for (var i = 0; i < terms.length; i++) {
          // simple check without regex
          if (text.includes(terms[i])) { nodesToReplace.push(node); break; }
        }
      }

      nodesToReplace.forEach(function(textNode) {
        var html = textNode.nodeValue;
        var replaced = false;
        var sortedTerms = terms.sort(function(a, b) { return b.length - a.length; });
        
        for (var j = 0; j < sortedTerms.length; j++) {
          var term = sortedTerms[j];
          if (html.includes(term)) {
            var splitHtml = html.split(term);
            html = splitHtml.join('<span class="jargon-term" data-jargon="' + term + '">' + term + '</span>');
            replaced = true;
          }
        }
        
        if (replaced) {
          var span = document.createElement('span');
          span.innerHTML = html;
          textNode.parentNode.replaceChild(span, textNode);
        }
      });

      var tooltip = document.getElementById('jargon-tooltip');
      var titleEl = document.getElementById('jargon-title');
      var descEl = document.getElementById('jargon-desc');
      var closeBtn = document.getElementById('jargon-close');

      function showTooltip(term, rect) {
        titleEl.textContent = term;
        descEl.innerHTML = '<strong>[쉽게 말해]</strong> ' + dictionary[term];
        tooltip.style.display = 'block';
        tooltip.setAttribute('aria-hidden', 'false');
        
        if (window.innerWidth < 768) {
          tooltip.classList.add('jargon-tooltip--mobile');
          tooltip.style.top = 'auto';
          tooltip.style.left = '0';
          tooltip.style.bottom = '0';
        } else {
          tooltip.classList.remove('jargon-tooltip--mobile');
          var tooltipRect = tooltip.getBoundingClientRect();
          var top = rect.top + window.scrollY - tooltipRect.height - 10;
          var left = rect.left + window.scrollX - (tooltipRect.width / 2) + (rect.width / 2);
          
          if (top < window.scrollY) top = rect.bottom + window.scrollY + 10;
          if (left < 0) left = 10;
          if (left + tooltipRect.width > window.innerWidth) left = window.innerWidth - tooltipRect.width - 10;
          
          tooltip.style.top = top + 'px';
          tooltip.style.left = left + 'px';
        }
        tooltip.classList.add('show');
      }

      function hideTooltip() {
        tooltip.classList.remove('show');
        setTimeout(function() { tooltip.style.display = 'none'; }, 200);
      }

      var jargonEls = document.querySelectorAll('.jargon-term');
      for (var k = 0; k < jargonEls.length; k++) {
        jargonEls[k].addEventListener('mouseenter', function(e) {
          if (window.innerWidth >= 768) showTooltip(e.target.getAttribute('data-jargon'), e.target.getBoundingClientRect());
        });
        jargonEls[k].addEventListener('mouseleave', function() {
          if (window.innerWidth >= 768) hideTooltip();
        });
        jargonEls[k].addEventListener('click', function(e) {
          e.preventDefault();
          showTooltip(e.target.getAttribute('data-jargon'), e.target.getBoundingClientRect());
        });
      }

      closeBtn.addEventListener('click', hideTooltip);
      document.addEventListener('click', function(e) {
        if (!tooltip.contains(e.target) && !e.target.classList.contains('jargon-term')) {
          hideTooltip();
        }
      });

    } catch (e) { console.error('Failed to load dictionary', e); }
  });
</script>
