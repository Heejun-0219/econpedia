---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import dailyArticles from '../data/daily-articles.json';
import fs from 'fs';
import path from 'path';
import '../styles/home-redesign.css';

const latestBriefings = [...dailyArticles]
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

let marketData = { weatherData: { weather: 'sunny', emoji: '☀️', label: '맑음', headline: '오늘은 평화로운 날이에요', color: '#34d399', walletImpacts: [] }, raw: { oil: { price: 68.2, changePercent: -3.1 }, kospi: { price: 2684, changePercent: 0.4 }, krw: { price: 1475, changePercent: 0.6 }, sp500: { price: 4.32, changePercent: 0 } } };
try {
  const mdPath = path.resolve(process.cwd(), '.market-data.json');
  if (fs.existsSync(mdPath)) {
    marketData = JSON.parse(fs.readFileSync(mdPath, 'utf8'));
    if (!marketData.weatherData) marketData.weatherData = { weather: 'cloudy', emoji: '☁️', label: '흐림', headline: '위젯 데이터를 로딩중입니다...', color: '#94a3b8', walletImpacts: [] };
    if (!marketData.raw) marketData.raw = { oil: { price: 68.2, changePercent: -3.1 }, kospi: { price: 2684, changePercent: 0.4 }, krw: { price: 1475, changePercent: 0.6 }, sp500: { price: 4.32, changePercent: 0 } };
  }
} catch (e) {
  console.warn('Could not load .market-data.json', e.message);
}

const w = marketData.weatherData;
const r = marketData.raw;

const categories = [
  { icon: '📘', title: '기초 경제학', desc: '"GDP가 오르면 내 월급도 오르나요?"', count: '24편 · 평균 4분', href: '/economy/basics' },
  { icon: '📈', title: '투자 기초', desc: '"ETF와 펀드, 뭐가 다른가요?"', count: '18편 · 평균 5분', href: '/economy/investment' },
  { icon: '💰', title: '생활 금융', desc: '"전세 vs 월세, 지금은 뭐가 유리?"', count: '21편 · 평균 3분', href: '/economy/finance' },
  { icon: '🌏', title: '글로벌 경제', desc: '"미국 금리가 한국 집값에 왜?"', count: '15편 · 평균 6분', href: '/economy/global' },
];

function formatDateShort(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const month = d.getMonth() + 1;
  const day = d.getDate();
  const weekdays = ['일', '월', '화', '수', '목', '금', '토'];
  const weekday = weekdays[d.getDay()];
  return { m: `${month}월`, d: `${day}`, w: weekday };
}

const today = new Date();
const weekdaysEn = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
const weatherIcons = ['☀️', '⛅', '🌧️', '🌩️'];
const weatherLabels = ['맑음', '흐림', '비', '폭풍'];

let pastWeekData = [];
let nextWeekData = [];
try {
  const hPath = path.resolve(process.cwd(), 'src/data/weather-history.json');
  if (fs.existsSync(hPath)) pastWeekData = JSON.parse(fs.readFileSync(hPath, 'utf8'));
  const fPath = path.resolve(process.cwd(), 'src/data/weather-forecast.json');
  if (fs.existsSync(fPath)) nextWeekData = JSON.parse(fs.readFileSync(fPath, 'utf8'));
} catch (e) {
  console.warn('Could not load weather JSONs', e.message);
}

function generateWeekData(offsetDays, sourceData, forceCssClass) {
  return Array.from({length: 7}).map((_, i) => {
    const d = new Date(today);
    d.setDate(today.getDate() + offsetDays + i);
    const dateStr = d.toISOString().split('T')[0];
    
    let icon = '☀️';
    let label = '맑음';
    let event = '';
    
    const matched = sourceData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = matched.label;
      event = matched.event || '';
    } else {
      const hash = d.getDate() * 37 % 4;
      icon = weatherIcons[hash];
      label = weatherLabels[hash];
    }
    
    return {
      dow: weekdaysEn[d.getDay()],
      dt: `${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`,
      icon,
      label,
      event,
      cssClass: forceCssClass
    };
  });
}

const pastWeek = generateWeekData(-7, pastWeekData, 'past');
const nextWeek = generateWeekData(1, nextWeekData, '');

const thisWeek = Array.from({length: 7}).map((_, i) => {
  const d = new Date(today);
  d.setDate(today.getDate() - 5 + i); // 5 days past, today, tomorrow
  const isToday = i === 5;
  const isTomorrow = i === 6;
  const isPast = i < 5;
  const dateStr = d.toISOString().split('T')[0];
  
  let icon = '☀️';
  let label = '맑음';
  let event = '';
  
  if (isToday) {
    icon = w.emoji || '☀️';
    label = w.label || '맑음';
  } else if (isTomorrow) {
    const matched = nextWeekData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = `예보: ${matched.label}`;
      event = matched.event || '';
    } else {
      icon = '⛅'; label = '예보: 흐림';
    }
  } else {
    const matched = pastWeekData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = matched.label;
      event = matched.event || '';
    } else {
      const hash = d.getDate() * 37 % 4;
      icon = weatherIcons[hash];
      label = weatherLabels[hash];
    }
  }

  return {
    dow: isToday ? '오늘' : isTomorrow ? '내일' : weekdaysEn[d.getDay()],
    dt: `${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`,
    icon,
    label,
    event,
    cssClass: isToday ? 'today' : isPast ? 'past' : ''
  };
});
---

<BaseLayout
  title="경제 백과사전"
  description="경제 초보자를 전문가로 만드는 경제 백과사전. GDP, 주식, ETF, 금리 등 복잡한 경제 개념을 쉽고 재밌게 배워보세요."
  hideSubHub={true}
>
  <div class="container" style="padding-top: 40px; padding-bottom: 80px;">

    <!-- ============================================================
      ISSUE 07 — WEEKLY WEATHER
    ============================================================ -->
    <div class="i7-strip">
      <div class="i7-top">
        <div>
          <div class="lb" id="weather-title">이번 주 경제 날씨</div>
          <h4 id="weather-headline">이번 주 시장은 대체로 <b style="color:var(--color-accent-primary)">맑음</b>, 목요일 하루만 비 소식이에요.</h4>
        </div>
        <div class="actions">
          <div class="b on">이번 주</div>
          <div class="b">지난 주</div>
          <div class="b">다음 주 예보</div>
        </div>
      </div>
      <div class="i7-week" id="weather-week-container">
        {thisWeek.map((d) => (
          <div class={`i7-day ${d.cssClass}`}>
            <div class="dow">{d.dow}</div>
            <div class="dt">{d.dt}</div>
            <div class="icon">{d.icon}</div>
            <div class="lbl">{d.label}</div>
            {d.event && <div style="font-size:0.6rem; color:var(--color-accent-danger); margin-top:2px; font-weight:700; line-height:1.2; letter-spacing:-0.05em; word-break:keep-all;">{d.event}</div>}
          </div>
        ))}
      </div>
      <div class="i7-legend">
        <span>☀️ <b>맑음</b> · 주요 이벤트 없음</span>
        <span>⛅ <b>흐림</b> · 지표 발표</span>
        <span>🌧️ <b>비</b> · 변동성 큼</span>
        <span>🌩️ <b>폭풍</b> · 위기 경보</span>
        <span style="margin-left:auto;color:var(--color-accent-primary);font-weight:700">매주 금요일, 다음 주 예보가 올라와요 →</span>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 01 — HERO REBUILD
    ============================================================ -->
    <div class="h1-hero">
      <div class="pill"><span class="d"></span>LIVE · {formatDateShort(new Date().toISOString().split('T')[0]).m} {formatDateShort(new Date().toISOString().split('T')[0]).d}일 {formatDateShort(new Date().toISOString().split('T')[0]).w} · 업데이트</div>
      <h3>{w.headline || '기름값이 훅 떨어졌습니다. 주유소는 조금만 더 기다리세요.'}</h3>
      <div class="abs">{w.walletSummary ? w.walletSummary.split('\n')[0] : '국제 유가가 3.1% 하락해 다음 주 국내 주유소 가격에 반영될 예정입니다.'} <b>{w.walletImpacts?.[0]?.label}</b></div>
      <div class="cta-row">
        <a href="/daily" class="cta-p" style="text-decoration:none">오늘 브리핑 3분 읽기 →</a>
        <a href="#newsletter-block" class="cta-s" style="text-decoration:none">매일 아침 받기</a>
        <div class="cta-t">오늘 <b>1,284명</b>이 이미 읽음</div>
      </div>
      <div class="h1-impact">
        <div class={`h1-imp ${r.oil?.changePercent > 0 ? 'up' : 'dn'}`}><div class="t">원유(WTI)</div><div class="v">${r.oil?.price.toFixed(2) || '68.20'}</div><div class="d">{r.oil?.changePercent > 0 ? '↑' : '↓'} {Math.abs(r.oil?.changePercent || 3.1).toFixed(2)}%</div></div>
        <div class={`h1-imp ${r.kospi?.changePercent > 0 ? 'up' : 'dn'}`}><div class="t">코스피</div><div class="v">{r.kospi?.price.toFixed(2) || '2,684'}</div><div class="d">{r.kospi?.changePercent > 0 ? '↑' : '↓'} {Math.abs(r.kospi?.changePercent || 0.4).toFixed(2)}%</div></div>
        <div class={`h1-imp ${r.krw?.changePercent > 0 ? 'up' : 'dn'}`}><div class="t">원/달러</div><div class="v">₩{r.krw?.price.toFixed(2) || '1,475'}</div><div class="d">{r.krw?.changePercent > 0 ? '↑' : '↓'} {Math.abs(r.krw?.changePercent || 0.6).toFixed(2)}%</div></div>
        <div class={`h1-imp ${r.sp500?.changePercent > 0 ? 'up' : 'dn'}`}><div class="t">S&P 500</div><div class="v">{r.sp500?.price.toFixed(2) || '5432.10'}</div><div class="d">{r.sp500?.changePercent > 0 ? '↑' : '↓'} {Math.abs(r.sp500?.changePercent || 0).toFixed(2)}%</div></div>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 02 — PRIMARY CTA TRIPLE
    ============================================================ -->
    <div class="i2-triple">
      <div class="i2-card">
        <div class="ico">📬</div>
        <div class="t">매일 아침 7시에 받기</div>
        <div class="d">이코노가 쓴 3분 브리핑을 이메일·텔레그램으로. 원할 때 언제든 해지 가능.</div>
        <div class="m">구독자 <b style="color:var(--color-text-primary)">14,382명</b> · 평균 열람률 <b style="color:var(--color-text-primary)">64%</b></div>
        <button class="btn sec" onclick="document.getElementById('newsletter-block').scrollIntoView({behavior:'smooth'})">뉴스레터 구독 →</button>
      </div>
      <div class="i2-card rec">
        <div class="ico">💼</div>
        <div class="t">내 포트폴리오 연결하기</div>
        <div class="d">오늘 뉴스가 내 ETF·주식에 얼마만큼의 영향인지 자동으로 해석해 드립니다. 읽기 전용 연결.</div>
        <div class="m">지원사 <b style="color:var(--color-text-primary)">토스증권·키움·미래에셋</b> · 2단계 · 30초</div>
        <a href="/portfolio" class="btn pri" style="text-decoration:none; display:block">샘플 먼저 보기 →</a>
      </div>
      <div class="i2-card">
        <div class="ico">📚</div>
        <div class="t">경제 기초부터 시작</div>
        <div class="d">GDP·금리·환율. 필수 경제 용어 3개를 10분 안에. 어제 뉴스가 이해되게.</div>
        <div class="m">누적 완주 <b style="color:var(--color-text-primary)">8,240명</b> · 소요 <b style="color:var(--color-text-primary)">10분</b></div>
        <a href="/economy/basics" class="btn sec" style="text-decoration:none; display:block">학습 시작 →</a>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 03 — PORTFOLIO SAMPLE
    ============================================================ -->
    <div class="i3-frame">
      <div class="i3-top">
        <div>
          <div class="l">만약 당신의 포트폴리오가 이렇다면 — 데모 미리보기</div>
          <div class="h">오늘 뉴스 영향 · <span style="color:#6ee7b7">+₩42,180</span> (+0.38%)</div>
          <div class="s">국제 유가 하락이 <b>운송·항공주에 긍정</b>, <b>정유주에 부정</b>으로 작용. 당신 포트폴리오 기준 순영향은 양(+).</div>
        </div>
        <span class="i3-preview-tag">DEMO · NOT YOUR DATA</span>
      </div>
      <div class="i3-holdings">
        <div class="i3-hold">
          <div class="n"><span>TIGER 여행레저 ETF</span><span class="t">수혜</span></div>
          <div class="w">보유 비중 32% · ₩3,520,000</div>
          <div class="bar"><div class="fl" style="width:24%"></div></div>
          <div class="v up">+₩28,160 · +0.80%</div>
          <div class="e">유가 하락 → 항공·여행 마진 개선</div>
        </div>
        <div class="i3-hold">
          <div class="n"><span>삼성전자</span><span class="t">소폭 수혜</span></div>
          <div class="w">보유 비중 45% · ₩4,950,000</div>
          <div class="bar"><div class="fl" style="width:8%"></div></div>
          <div class="v up">+₩19,800 · +0.40%</div>
          <div class="e">환율 상승 반사이익</div>
        </div>
        <div class="i3-hold">
          <div class="n"><span>SK이노베이션</span><span class="t dn">영향</span></div>
          <div class="w">보유 비중 23% · ₩2,530,000</div>
          <div class="bar"><div class="fl dn" style="width:15%"></div></div>
          <div class="v dn">−₩5,780 · −0.23%</div>
          <div class="e">유가 하락 → 정제 마진 축소</div>
        </div>
      </div>
      <div class="i3-ctas">
        <a href="/wallet" class="cta-connect" style="text-decoration:none">내 포트폴리오 연결하기 (30초) →</a>
        <a href="/portfolio" class="cta-demo" style="text-decoration:none">데모 자세히 보기</a>
      </div>
      <div class="i3-foot">
        <span>🔒 읽기 전용 연결 · OAuth</span>
        <span>✓ 오픈뱅킹 인증</span>
        <span>✓ 3,214명이 이미 연결</span>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 04 — CATEGORY 4+3
    ============================================================ -->
    <div class="section-wrap">
      <div class="sec-head">
        <div>
          <div class="sec-head-l">주제별로 읽기</div>
          <h4 class="sec-head-h">궁금한 것부터 시작하세요</h4>
        </div>
