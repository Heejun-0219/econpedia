---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import dailyArticles from '../data/daily-articles.json';

import fs from 'fs';
import path from 'path';

const latestBriefings = [...dailyArticles]
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

// Load market data for the weather widget
let marketData = { weatherData: { weather: 'sunny', emoji: '☀️', label: '맑음', headline: '오늘은 평화로운 날이에요', color: '#34d399', walletImpacts: [] } };
try {
  const mdPath = path.resolve(process.cwd(), '.market-data.json');
  if (fs.existsSync(mdPath)) {
    marketData = JSON.parse(fs.readFileSync(mdPath, 'utf8'));
    if (!marketData.weatherData) marketData.weatherData = { weather: 'cloudy', emoji: '☁️', label: '흐림', headline: '위젯 데이터를 로딩중입니다...', color: '#94a3b8', walletImpacts: [] };
  }
} catch (e) {
  console.warn('Could not load .market-data.json', e.message);
}

const w = marketData.weatherData;

const categories = [
  { icon: 'book',       title: '기초 경제학', desc: 'GDP, 인플레이션, 금리, 환율 등 경제의 기본 개념을 쉽게 배워보세요.', count: '24개 기사', href: '/economy/basics' },
  { icon: 'chart-line', title: '투자 기초',   desc: '주식, 채권, ETF, 부동산 등 투자의 첫 걸음을 시작하세요.', count: '18개 기사', href: '/economy/investment' },
  { icon: 'wallet',     title: '생활 금융',   desc: '신용점수, 대출, 보험, 세금 등 일상 속 금융 상식을 알려드립니다.', count: '21개 기사', href: '/economy/finance' },
  { icon: 'globe',      title: '글로벌 경제', desc: '미국, 중국, 유럽 등 세계 경제의 흐름을 한눈에 파악하세요.', count: '15개 기사', href: '/economy/global' },
  { icon: 'building',   title: '기업 분석',   desc: '재무제표 읽기, 산업 분석 등 기업을 보는 눈을 키워보세요.', count: '12개 기사', href: '/economy/corporate' },
  { icon: 'gauge',      title: '경제 지표 해설', desc: 'CPI, PMI, 고용지표 등 경제 뉴스의 핵심 지표를 해설합니다.', count: '16개 기사', href: '/economy/indicators' },
  { icon: 'trend',      title: '경제 트렌드', desc: 'AI 경제, ESG, 디지털 화폐 등 최신 경제 트렌드를 분석합니다.', count: '9개 기사', href: '/economy/trends' },
];

const featuredArticles = [
  {
    category: '기초 경제학',
    title: 'GDP란 무엇인가? — 국가 경제의 건강 검진표를 읽는 법',
    excerpt: 'GDP는 한 나라의 경제 크기를 나타내는 가장 기본적인 지표입니다. 우리나라의 GDP가 올랐다, 내렸다는 뉴스를 들을 때, 그것이 내 삶에 어떤 영향을 미치는지 알아보세요.',
    readingTime: '8분',
    date: '2026.04.01',
    href: '/economy/basics/what-is-gdp',
  },
  {
    category: '투자 기초',
    title: 'ETF 완전 정복 — 주식보다 안전하고, 적금보다 수익률 높은 투자법',
    excerpt: '"주식은 무서운데 적금 이자는 너무 낮아." 이런 고민을 가진 분들에게 ETF가 답이 될 수 있습니다. 초보자도 쉽게 시작할 수 있는 ETF 투자의 모든 것.',
    readingTime: '12분',
    date: '2026.04.01',
    href: '/economy/investment/etf-guide',
  },
  {
    category: '생활 금융',
    title: '신용점수 올리는 5가지 확실한 방법 — 은행이 절대 알려주지 않는 비밀',
    excerpt: '신용점수 1점 차이로 대출 금리가 달라집니다. 지금 당장 실천할 수 있는 신용점수 관리법을 전문가가 알려드립니다.',
    readingTime: '6분',
    date: '2026.04.01',
    href: '/economy/finance/credit-score-tips',
  },
];

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const month = d.getMonth() + 1;
  const day = d.getDate();
  const weekdays = ['일', '월', '화', '수', '목', '금', '토'];
  const weekday = weekdays[d.getDay()];
  return `${month}월 ${day}일 (${weekday})`;
}
---

<BaseLayout
  title="경제 백과사전"
  description="경제 초보자를 전문가로 만드는 경제 백과사전. GDP, 주식, ETF, 금리 등 복잡한 경제 개념을 쉽고 재밌게 배워보세요."
>
  <!-- Hero (Weather Widget) -->
  <section class="hero" style={`background: radial-gradient(circle at center, ${w.color}15 0%, transparent 70%); border-bottom: 1px solid ${w.color}30;`}>
    <div class="container" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
      <span class="hero__badge" style={`color: ${w.color}; background: ${w.color}20; border: 1px solid ${w.color}40;`}>
        오늘의 경제 날씨
      </span>
      <h1 class="hero__title" style="margin-top: 24px; font-size: clamp(40px, 8vw, 64px); margin-bottom: 16px; display: flex; align-items: center; justify-content: center; gap: 16px;">
        <Icon name={`weather-${w.weather}`} size={64} class="hero__weather-icon" /> {w.label}
      </h1>
      <p class="hero__subtitle" style="font-size: clamp(18px, 4vw, 24px); font-weight: 500; color: var(--text-primary); margin-bottom: 48px; line-height: 1.4; word-break: keep-all;">
        "{w.headline}"
      </p>

      {w.walletImpacts && w.walletImpacts.length > 0 && (
        <div style="display:flex; flex-direction:column; gap:12px; width: 100%; max-width: 600px; text-align: left;">
          {w.walletImpacts.map((im) => (
            <div style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px; padding: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="display: inline-flex; color: var(--text-muted);">
                  <Icon name={
                    im.category === 'housing' ? 'home' :
                    im.category === 'travel' ? 'airplane' :
                    im.category === 'grocery' ? 'shopping-cart' :
                    im.category === 'gasoline' ? 'gas-pump' :
                    im.category === 'investment' ? 'chart-pie' :
                    im.category === 'crypto' ? 'currency-bitcoin' :
                    im.category === 'us_stock' ? 'flag-usa' : 'smile'
                  } size={28} />
                </span>
                <span style="font-size: 16px; font-weight: 700; color: var(--color-text-primary); line-height: 1.3;" set:html={im.label.replace('·', '<br/>')}></span>
              </div>
              <div style={`font-size: 18px; font-weight: 700; color: ${im.sentiment === 'positive' ? 'var(--color-accent-primary)' : im.sentiment === 'negative' ? 'var(--color-accent-danger)' : 'var(--color-text-primary)'}; text-align: right;`}>
                {im.message.split(' (')[0]}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Daily Briefing (과거 브리핑 아카이브) -->
  {latestBriefings.length > 0 && (
    <section class="daily-section" id="daily-briefing">
      <div class="container">
        <div class="daily-section__header">
          <div class="daily-section__label">아카이브</div>
          <h2 class="section-title">과거 브리핑 모아보기</h2>
          <p class="daily-section__subtitle">시그널이 발생했던 날들의 상세 분석을 다시 확인하세요.</p>
        </div>

        <div class="daily-card-list">
          {latestBriefings.map((brief, idx) => (
            <a href={brief.href} class={`daily-card ${idx === 0 ? 'daily-card--featured' : ''}`} id={`briefing-${brief.date}`}>
              <div class="daily-card__top">
                <span class="daily-card__date">{formatDate(brief.date)}</span>
              </div>
              <h3 class="daily-card__title">{brief.title}</h3>
              <p class="daily-card__excerpt">{brief.excerpt}</p>
              <div class="daily-card__footer">
                <span class="daily-card__author"><Icon name="robot" size={14} class="daily-card__author-icon" /> EconPedia AI</span>
                <span class="daily-card__read">읽기 →</span>
              </div>
            </a>
          ))}
        </div>

        <div class="daily-section__cta">
          <a href="/daily" class="daily-section__cta-link"><Icon name="library" size={16} class="daily-section__cta-icon" /> 모든 브리핑 보기 →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="categories">
    <div class="container">
      <div class="section-header">
        <p class="section-label">카테고리</p>
        <h2 class="section-title">무엇을 배우고 싶으세요?</h2>
      </div>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="category-card" id={`category-${cat.title}`}>
            <div class="category-card__icon"><Icon name={cat.icon} size={28} /></div>
            <h3 class="category-card__title">{cat.title}</h3>
            <p class="category-card__desc">{cat.desc}</p>
            <span class="category-card__count"><Icon name="document" size={13} class="category-card__count-icon" /> {cat.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="articles">
    <div class="container">
      <div class="section-header">
        <p class="section-label">인기 기사</p>
        <h2 class="section-title">지금 가장 많이 읽히는 글</h2>
      </div>
      <div class="article-grid">
        {featuredArticles.map((article) => (
          <a href={article.href} class="article-card" id={`article-${article.title.slice(0, 10)}`}>
            <div class="article-card__body">
              <span class="article-card__category">{article.category}</span>
              <h3 class="article-card__title">{article.title}</h3>
              <p class="article-card__excerpt">{article.excerpt}</p>
              <div class="article-card__meta">
                <span class="article-card__reading-time">⏱ {article.readingTime} 읽기</span>
                <span>{article.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
