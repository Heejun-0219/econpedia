---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import dailyArticles from '../data/daily-articles.json';
import blogArticles from '../data/blog-articles.json';
import weatherSummaryData from '../data/weather-summary.json';
import demoPortfolioData from '../data/demo-portfolio.json';
import ctaCardsData from '../data/cta-cards.json';
import fs from 'fs';
import path from 'path';
import '../styles/home-redesign.css';
import MarketTicker from '../components/MarketTicker.jsx';

const latestBriefings = [...dailyArticles]
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

let marketData = { weatherData: { weather: 'sunny', emoji: '☀️', label: '맑음', headline: '오늘은 평화로운 날이에요', color: '#34d399', walletImpacts: [] }, raw: { oil: { price: 68.2, changePercent: -3.1 }, kospi: { price: 2684, changePercent: 0.4 }, krw: { price: 1475, changePercent: 0.6 }, sp500: { price: 4.32, changePercent: 0 } } };
try {
  const mdPath = path.resolve(process.cwd(), '.market-data.json');
  if (fs.existsSync(mdPath)) {
    marketData = JSON.parse(fs.readFileSync(mdPath, 'utf8'));
    if (!marketData.weatherData) marketData.weatherData = { weather: 'cloudy', emoji: '☁️', label: '흐림', headline: '위젯 데이터를 로딩중입니다...', color: '#94a3b8', walletImpacts: [] };
    if (!marketData.raw) marketData.raw = { oil: { price: 68.2, changePercent: -3.1 }, kospi: { price: 2684, changePercent: 0.4 }, krw: { price: 1475, changePercent: 0.6 }, sp500: { price: 4.32, changePercent: 0 } };
  }
} catch (e) {
  console.warn('Could not load .market-data.json', e.message);
}

const w = marketData.weatherData;
const r = marketData.raw;

function getCategoryCount(keywords) {
  return blogArticles.filter(a => a.tags?.some(t => keywords.includes(t))).length 
       + dailyArticles.filter(a => keywords.some(k => a.title.includes(k) || a.excerpt.includes(k))).length;
}

const cat1Count = getCategoryCount(['거시경제', '기초', 'GDP']) || 24;
const cat2Count = getCategoryCount(['투자', '자산', '주식', '코스피', '나스닥', 'ETF']) || 18;
const cat3Count = getCategoryCount(['부동산', '세금', '연금', '생활', '전세', '월세']) || 21;
const cat4Count = getCategoryCount(['환율', '글로벌', '미국', '금리']) || 15;

const categories = [
  { icon: '📘', title: '기초 경제학', desc: '"GDP가 오르면 내 월급도 오르나요?"', count: `${cat1Count}편 · 평균 4분`, href: '/economy/basics' },
  { icon: '📈', title: '투자 기초', desc: '"ETF와 펀드, 뭐가 다른가요?"', count: `${cat2Count}편 · 평균 5분`, href: '/economy/investment' },
  { icon: '💰', title: '생활 금융', desc: '"전세 vs 월세, 지금은 뭐가 유리?"', count: `${cat3Count}편 · 평균 3분`, href: '/economy/finance' },
  { icon: '🌏', title: '글로벌 경제', desc: '"미국 금리가 한국 집값에 왜?"', count: `${cat4Count}편 · 평균 6분`, href: '/economy/global' },
];

const corpCount = getCategoryCount(['기업', '실적', '분석']) || 12;
const indicCount = getCategoryCount(['지표', 'PMI', '물가', '데이터']) || 16;
const trendCount = getCategoryCount(['트렌드', '이슈', '전망']) || 9;

function formatDateShort(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const month = d.getMonth() + 1;
  const day = d.getDate();
  const weekdays = ['일', '월', '화', '수', '목', '금', '토'];
  const weekday = weekdays[d.getDay()];
  return { m: `${month}월`, d: `${day}`, w: weekday };
}

const today = new Date();
const weekdaysEn = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
const weatherIcons = ['☀️', '⛅', '🌧️', '🌩️'];
const weatherLabels = ['맑음', '흐림', '비', '폭풍'];

let pastWeekData = [];
let nextWeekData = [];
try {
  const hPath = path.resolve(process.cwd(), 'src/data/weather-history.json');
  if (fs.existsSync(hPath)) pastWeekData = JSON.parse(fs.readFileSync(hPath, 'utf8'));
  const fPath = path.resolve(process.cwd(), 'src/data/weather-forecast.json');
  if (fs.existsSync(fPath)) nextWeekData = JSON.parse(fs.readFileSync(fPath, 'utf8'));
} catch (e) {
  console.warn('Could not load weather JSONs', e.message);
}

function generateWeekData(offsetDays, sourceData, forceCssClass) {
  return Array.from({length: 7}).map((_, i) => {
    const d = new Date(today);
    d.setDate(today.getDate() + offsetDays + i);
    const dateStr = d.toISOString().split('T')[0];
    
    let icon = '☀️';
    let label = '맑음';
    let event = '';
    
    const matched = sourceData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = matched.label;
      event = matched.event || '';
    } else {
      const hash = d.getDate() * 37 % 4;
      icon = weatherIcons[hash];
      label = weatherLabels[hash];
    }
    
    return {
      dow: weekdaysEn[d.getDay()],
      dt: `${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`,
      icon,
      label,
      event,
      cssClass: forceCssClass
    };
  });
}

const pastWeek = generateWeekData(-7, pastWeekData, 'past');
const nextWeek = generateWeekData(1, nextWeekData, '');

const thisWeek = Array.from({length: 7}).map((_, i) => {
  const d = new Date(today);
  d.setDate(today.getDate() - 5 + i); // 5 days past, today, tomorrow
  const isToday = i === 5;
  const isTomorrow = i === 6;
  const isPast = i < 5;
  const dateStr = d.toISOString().split('T')[0];
  
  let icon = '☀️';
  let label = '맑음';
  let event = '';
  
  if (isToday) {
    icon = w.emoji || '☀️';
    label = w.label || '맑음';
  } else if (isTomorrow) {
    const matched = nextWeekData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = `예보: ${matched.label}`;
      event = matched.event || '';
    } else {
      icon = '⛅'; label = '예보: 흐림';
    }
  } else {
    const matched = pastWeekData.find(x => x.date === dateStr);
    if (matched) {
      icon = matched.emoji;
      label = matched.label;
      event = matched.event || '';
    } else {
      const hash = d.getDate() * 37 % 4;
      icon = weatherIcons[hash];
      label = weatherLabels[hash];
    }
  }

  return {
    dow: isToday ? '오늘' : isTomorrow ? '내일' : weekdaysEn[d.getDay()],
    dt: `${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`,
    icon,
    label,
    event,
    cssClass: isToday ? 'today' : isPast ? 'past' : ''
  };
});

// ─── 트래픽 메트릭 로드 (빌드 타임) ─────────────────────
let siteStats = { 
  total_visitors: 0, 
  daily_visitors: 0,
  subscribers: 14382,
  openRate: "64",
  rating: "4.8",
  course_completions: 8240,
  portfolio_users: 3214
};
try {
  // 배포된 환경의 API에서 통계 데이터를 긁어옴 (SSG 빌드 시 최신값 반영)
  const statsRes = await fetch('https://econpedia.dedyn.io/api/stats');
  if (statsRes.ok) {
    const data = await statsRes.json();
    siteStats = { ...siteStats, ...data };
  }
} catch (err) {
  console.warn('⚠️ 빌드 중 사이트 통계 로드 실패:', err.message);
}

// 가장 변동성이 심한 4가지 지표 계산
const rawItems = [
  { id: 'kospi', title: '코스피', prefix: '', suffix: '', data: r.kospi },
  { id: 'nasdaq', title: '나스닥', prefix: '', suffix: '', data: r.nasdaq },
  { id: 'sp500', title: 'S&P 500', prefix: '', suffix: '', data: r.sp500 },
  { id: 'krw', title: '원/달러', prefix: '₩', suffix: '', data: r.krw },
  { id: 'oil', title: '원유(WTI)', prefix: '$', suffix: '', data: r.oil },
  { id: 'bitcoin', title: '비트코인', prefix: '$', suffix: '', data: r.bitcoin }
].filter(item => item.data);

const topImpacts = rawItems.sort((a, b) => Math.abs(b.data.changePercent || 0) - Math.abs(a.data.changePercent || 0)).slice(0, 4);

---

<BaseLayout
  title="경제 백과사전"
  description="경제 초보자를 전문가로 만드는 경제 백과사전. GDP, 주식, ETF, 금리 등 복잡한 경제 개념을 쉽고 재밌게 배워보세요."
  hideSubHub={true}
>
  <div class="container" style="padding-top: 40px; padding-bottom: 80px;">

    <!-- ============================================================
      ISSUE 07 — WEEKLY WEATHER
    ============================================================ -->
    <div class="i7-strip">
      <div class="i7-top">
        <div>
          <div class="lb" id="weather-title">이번 주 경제 날씨</div>
          <h4 id="weather-headline">이번 주 시장은 대체로 <b style="color:var(--color-accent-primary)">맑음</b>, 목요일 하루만 비 소식이에요.</h4>
        </div>
        <div class="actions">
          <div class="b on">이번 주</div>
          <div class="b">지난 주</div>
          <div class="b">다음 주 예보</div>
        </div>
      </div>
      <div class="i7-week" id="weather-week-container">
        {thisWeek.map((d) => (
          <div class={`i7-day ${d.cssClass}`}>
            <div class="dow">{d.dow}</div>
            <div class="dt">{d.dt}</div>
            <div class="icon">{d.icon}</div>
            <div class="lbl">{d.label}</div>
            {d.event && <div style="font-size:0.6rem; color:var(--color-accent-danger); margin-top:2px; font-weight:700; line-height:1.2; letter-spacing:-0.05em; word-break:keep-all;">{d.event}</div>}
          </div>
        ))}
      </div>
      <div class="i7-legend">
        <span>☀️ <b>맑음</b> · 주요 이벤트 없음</span>
        <span>⛅ <b>흐림</b> · 지표 발표</span>
        <span>🌧️ <b>비</b> · 변동성 큼</span>
        <span>🌩️ <b>폭풍</b> · 위기 경보</span>
        <span style="margin-left:auto;color:var(--color-accent-primary);font-weight:700">매주 금요일, 다음 주 예보가 올라와요 →</span>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 01 — HERO REBUILD
    ============================================================ -->
    <div class="h1-hero">
      <div class="pill"><span class="d"></span>LIVE · {formatDateShort(new Date().toISOString().split('T')[0]).m} {formatDateShort(new Date().toISOString().split('T')[0]).d}일 {formatDateShort(new Date().toISOString().split('T')[0]).w} · 업데이트</div>
      <h3>{latestBriefings[0]?.title || w.headline || '기름값이 훅 떨어졌습니다. 주유소는 조금만 더 기다리세요.'}</h3>
      <div class="abs">{latestBriefings[0]?.excerpt || (w.walletSummary ? w.walletSummary.split('\n')[0] : '국제 유가가 3.1% 하락해 다음 주 국내 주유소 가격에 반영될 예정입니다.')} <b>{w.walletImpacts?.[0]?.label}</b></div>
      <div class="cta-row">
        <a href={latestBriefings[0] ? latestBriefings[0].href : '/daily'} class="cta-p" style="text-decoration:none">오늘 브리핑 3분 읽기 →</a>
        <a href="#newsletter-block" class="cta-s" style="text-decoration:none">매일 아침 받기</a>
        <div class="cta-t">이미 <b id="stat-daily-readers">{siteStats.daily_visitors.toLocaleString()}명</b>이 읽었어요. 함께해보세요!</div>
      </div>
      <div class="h1-impact">
        {topImpacts.map(impact => (
          <div id={`impact-${impact.id}`} class={`h1-imp ${impact.data.changePercent > 0 ? 'up' : 'dn'}`}>
            <div class="t">{impact.title}</div>
            <div class="v" id={`impact-${impact.id}-v`}>
              {impact.prefix}{Number(impact.data.price).toLocaleString('en-US', { minimumFractionDigits: impact.data.price >= 1000 && impact.id !== 'krw' ? 0 : 2, maximumFractionDigits: 2 })}{impact.suffix}
            </div>
            <div class="d" id={`impact-${impact.id}-d`}>
              {impact.data.changePercent > 0 ? '↑' : '↓'} {Math.abs(impact.data.changePercent || 0).toFixed(2)}%
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ============================================================
      ISSUE 02 — PRIMARY CTA TRIPLE
    ============================================================ -->
    <div class="i2-triple">
      {ctaCardsData.map(card => {
        const processedMetrics = card.metricsHtml
          .replace('{subscribers}', Number(siteStats.subscribers).toLocaleString())
          .replace('{openRate}', siteStats.openRate)
          .replace('{course_completions}', Number(siteStats.course_completions).toLocaleString());
          
        return (
          <div class={`i2-card ${card.isRecommended ? 'rec' : ''}`}>
            <div class="ico">{card.icon}</div>
            <div class="t">{card.title}</div>
            <div class="d">{card.description}</div>
            <div class="m" set:html={processedMetrics}></div>
            {card.button.type === 'scroll' ? (
              <button class={`btn ${card.button.style}`} onclick={`document.getElementById('${card.button.target}').scrollIntoView({behavior:'smooth'})`}>{card.button.text}</button>
            ) : (
              <a href={card.button.target} class={`btn ${card.button.style}`} style="text-decoration:none; display:block">{card.button.text}</a>
            )}
          </div>
        );
      })}
    </div>

    <!-- ============================================================
      ISSUE 03 — PORTFOLIO SAMPLE
    ============================================================ -->
    <div class="i3-frame">
      <div class="i3-top">
        <div>
          <div class="l">만약 당신의 포트폴리오가 이렇다면 — 데모 미리보기</div>
          <div class="h">오늘 뉴스 영향 · <span style="color:#6ee7b7">{demoPortfolioData.totalImpact}</span> ({demoPortfolioData.totalChangePercent})</div>
          <div class="s" set:html={demoPortfolioData.summary}></div>
        </div>
        <span class="i3-preview-tag">DEMO · NOT YOUR DATA</span>
      </div>
      <div class="i3-holdings">
        {demoPortfolioData.holdings.map(holding => (
          <div class="i3-hold">
            <div class="n"><span>{holding.name}</span><span class={`t ${holding.signalClass}`}>{holding.signalLabel}</span></div>
            <div class="w">{holding.weight}</div>
            <div class="bar"><div class={`fl ${holding.barClass}`} style={`width:${holding.barWidth}`}></div></div>
            <div class={`v ${holding.impactClass}`}>{holding.impactValue}</div>
            <div class="e">{holding.reason}</div>
          </div>
        ))}
      </div>
      <div class="i3-ctas">
        <a href="/wallet" class="cta-connect" style="text-decoration:none">내 포트폴리오 연결하기 (30초) →</a>
        <a href="/portfolio" class="cta-demo" style="text-decoration:none">데모 자세히 보기</a>
      </div>
      <div class="i3-foot">
        <span>🔒 읽기 전용 연결 · OAuth</span>
        <span>✓ 오픈뱅킹 인증</span>
        <span>✓ <span id="stat-portfolio-users">{Number(siteStats.portfolio_users).toLocaleString()}</span>명이 이미 연결</span>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 04 — CATEGORY 4+3
    ============================================================ -->
    <div class="section-wrap">
      <div class="sec-head">
        <div>
          <div class="sec-head-l">주제별로 읽기</div>
          <h4 class="sec-head-h">궁금한 것부터 시작하세요</h4>
        </div>
        <a href="/economy/trends" class="sec-head-r" style="text-decoration:none">전체 아카이브 {blogArticles.length + dailyArticles.length}편 →</a>
      </div>
      <div class="i4-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="i4-card" style="text-decoration:none">
            <div class="ico">{cat.icon}</div>
            <div class="t">{cat.title}</div>
            <div class="d">{cat.desc}</div>
            <div class="c"><span>{cat.count}</span><span>→</span></div>
          </a>
        ))}
      </div>
      <div class="i4-more">
        <span class="lb">그 외 읽을거리 →</span>
        <a href="/economy/corporate" class="pill" style="text-decoration:none">기업 분석<span class="n">{corpCount}</span></a>
        <a href="/economy/indicators" class="pill" style="text-decoration:none">경제 지표<span class="n">{indicCount}</span></a>
        <a href="/economy/trends" class="pill" style="text-decoration:none">트렌드<span class="n">{trendCount}</span></a>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 05 — HIERARCHY 3-TIER
    ============================================================ -->
    <div class="section-wrap">
      <div class="sec-head" style="margin-bottom:16px;">
        <div>
          <div class="sec-head-l">지난 브리핑</div>
          <h4 class="sec-head-h">놓친 날의 경제 한 줄</h4>
        </div>
      </div>
      <div class="i5-grid">
        {latestBriefings.length > 0 && (
          <a href={latestBriefings[0].href} class="i5-feature">
            <span class="badge">★ 이번 주 가장 많이 읽힌</span>
            <h4>{latestBriefings[0].title}</h4>
            <div class="ex">{latestBriefings[0].excerpt}</div>
            <div class="meta"><span>{formatDateShort(latestBriefings[0].date).m} {formatDateShort(latestBriefings[0].date).d}일</span><span>•</span><span>3분 읽기</span><span>•</span><span><b>2,481명</b> 읽음</span></div>
          </a>
        )}
        <div class="i5-small-stack">
          {latestBriefings.slice(1, 4).map(brief => {
            const dateInfo = formatDateShort(brief.date);
            return (
              <a href={brief.href} class="i5-small">
                <div class="date"><div class="d">{dateInfo.d}</div><div class="m">{dateInfo.m} {dateInfo.w}</div></div>
                <div class="body">
                  <div class="t">{brief.title}</div>
                  <div class="e">{brief.excerpt.substring(0, 40)}... · 3분 읽기</div>
                </div>
              </a>
            )
          })}
        </div>
      </div>
      <div class="i5-cats">
        <span class="lb">빠른 이동</span>
        <a href="#" class="search-tag" data-q="환율">환율</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="금리">금리</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="부동산">부동산</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="연금">연금</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="세금">세금</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="청년정책">청년정책</a><span class="sep">·</span>
        <a href="#" class="search-tag" data-q="가상자산">가상자산</a>
      </div>
    </div>

    <!-- ============================================================
      ISSUE 06 — NEWSLETTER CONVERT
    ============================================================ -->
    <div class="section-wrap" id="newsletter-block">
      <div class="i6-grid">
        <div class="i6-left">
          <div class="kick">📬 매일 아침 7시, 당신의 받은편지함으로</div>
          <h4>커피 내리는 3분, 경제 한 편이 끝나요.</h4>
          <div class="d">이코노가 직접 쓴 브리핑을 매일 아침 보내드려요. <b>읽는 데 3분</b>, 이해하는 데 30초. 원할 때 한 번에 해지할 수 있어요.</div>
          <div class="i6-proof">
            <div class="p"><div class="v" id="stat-subscribers">{Number(siteStats.subscribers).toLocaleString()}</div><div class="l">구독자</div></div>
            <div class="p"><div class="v" id="stat-openrate">{siteStats.openRate}%</div><div class="l">평균 열람률</div></div>
            <div class="p"><div class="v" id="stat-rating">{siteStats.rating}</div><div class="l">독자 만족도</div></div>
          </div>
          <form id="subscribe-form-new" class="i6-form">
            <input type="email" id="subscribe-email-new" placeholder="이메일 주소" required />
            <button type="submit" id="subscribe-btn-new">무료 구독</button>
          </form>
          <div id="subscribe-feedback-new" style="display:none; font-size:0.8rem; margin-top:8px; font-weight:600;"></div>
          <div class="priv" style="margin-top:12px;">✓ 스팸 발송 금지 · ✓ 한 번에 해지 가능 · ✓ 정보 판매 금지</div>
          <div style="margin-top: 18px; padding-top: 18px; border-top: 1px dashed var(--color-border); font-size: 0.82rem;">
            실시간 시황 알림만 빠르게 받고 싶다면? 
            <a href="https://t.me/econpedia_channel" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent-primary); font-weight: 700; text-decoration: none; margin-left: 4px;">
              텔레그램 채널 입장 ↗
            </a>
          </div>
        </div>
        <div class="i6-right">
          <div class="kick"><span>SAMPLE · 가장 최근 브리핑</span><b>{latestBriefings[0]?.date}</b></div>
          <div class="i6-sample">
            <div class="sh">{latestBriefings[0]?.title}</div>
            <div class="sm">by 이코노 · 3분 읽기</div>
            <div class="fade">
              <p>{latestBriefings[0]?.excerpt}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <script is:inline>
    (function () {
      const form = document.getElementById('subscribe-form-new');
      if (!form) return;

      const emailInput = document.getElementById('subscribe-email-new');
      const btn = document.getElementById('subscribe-btn-new');
      const feedback = document.getElementById('subscribe-feedback-new');

      function showFeedback(message, isSuccess) {
        feedback.textContent = message;
        feedback.style.color = isSuccess ? 'var(--color-accent-primary)' : 'var(--color-accent-danger)';
        feedback.style.display = 'block';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        if (!email) return;

        btn.disabled = true;
        btn.textContent = '...';
        feedback.style.display = 'none';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();

          if (res.ok && data.success) {
            showFeedback(data.message || '구독 신청이 완료됐습니다.', true);
            emailInput.value = '';
            btn.textContent = '구독 완료';
          } else {
            showFeedback(data.error || '오류가 발생했습니다. 다시 시도해주세요.', false);
            btn.disabled = false;
            btn.textContent = '무료 구독';
          }
        } catch (err) {
          showFeedback('네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.', false);
          btn.disabled = false;
          btn.textContent = '무료 구독';
        }
      });
    })();
  </script>

  <script is:inline define:vars={{pastWeek, thisWeek, nextWeek, weatherSummaryData}}>
    window.weatherTabsData = { pastWeek, thisWeek, nextWeek, summary: weatherSummaryData };
  </script>

  <script is:inline>
    (function () {
      const weatherContainer = document.getElementById('weather-week-container');
      const weatherTabs = document.querySelectorAll('.i7-top .actions .b');
      const weatherTitle = document.getElementById('weather-title');
      const weatherHeadline = document.getElementById('weather-headline');
      
      if (weatherContainer && weatherTabs.length === 3 && window.weatherTabsData) {
        weatherTabs.forEach((tab, idx) => {
          tab.addEventListener('click', () => {
            weatherTabs.forEach(t => t.classList.remove('on'));
            tab.classList.add('on');
            
            let data = [];
            if (idx === 0) {
              data = window.weatherTabsData.thisWeek;
              weatherTitle.textContent = window.weatherTabsData.summary.thisWeek.title;
              weatherHeadline.innerHTML = window.weatherTabsData.summary.thisWeek.headline;
            } else if (idx === 1) {
              data = window.weatherTabsData.pastWeek;
              weatherTitle.textContent = window.weatherTabsData.summary.pastWeek.title;
              weatherHeadline.innerHTML = window.weatherTabsData.summary.pastWeek.headline;
            } else {
              data = window.weatherTabsData.nextWeek;
              weatherTitle.textContent = window.weatherTabsData.summary.nextWeek.title;
              weatherHeadline.innerHTML = window.weatherTabsData.summary.nextWeek.headline;
            }
            
            weatherContainer.innerHTML = data.map(d => {
              const cssClass = d.cssClass || '';
              const evHtml = d.event ? `<div style="font-size:0.6rem; color:var(--color-accent-danger); margin-top:2px; font-weight:700; line-height:1.2; letter-spacing:-0.05em; word-break:keep-all;">${d.event}</div>` : '';
              return `
                <div class="i7-day ${cssClass}">
                  <div class="dow">${d.dow}</div>
                  <div class="dt">${d.dt}</div>
                  <div class="icon">${d.icon}</div>
                  <div class="lbl">${d.label}</div>
                  ${evHtml}
                </div>
              `;
            }).join('');
          });
        });
      }
    })();
  </script>

  <script is:inline>
    (function () {
      // stats fetch
      fetch('/api/stats')
        .then(res => res.json())
        .then(data => {
          if (!data) return;
          
          if (data.daily_visitors !== undefined) {
            const dailyEl = document.getElementById('stat-daily-readers');
            if (dailyEl) dailyEl.textContent = Number(data.daily_visitors).toLocaleString() + '명';
          }
          if (data.subscribers !== undefined) {
            const subEl = document.getElementById('stat-subscribers');
            const subEl2 = document.getElementById('stat-i2-subscribers');
            if (subEl) subEl.textContent = Number(data.subscribers).toLocaleString();
            if (subEl2) subEl2.textContent = Number(data.subscribers).toLocaleString() + '명';
          }
          if (data.openRate !== undefined) {
            const orEl = document.getElementById('stat-openrate');
            const orEl2 = document.getElementById('stat-i2-openrate');
            if (orEl) orEl.textContent = data.openRate + '%';
            if (orEl2) orEl2.textContent = data.openRate + '%';
          }
          if (data.rating !== undefined) {
            const rEl = document.getElementById('stat-rating');
            if (rEl) rEl.textContent = data.rating;
          }
          if (data.course_completions !== undefined) {
            const cEl = document.getElementById('stat-i2-completions');
            if (cEl) cEl.textContent = Number(data.course_completions).toLocaleString() + '명';
          }
          if (data.portfolio_users !== undefined) {
            const pEl = document.getElementById('stat-portfolio-users');
            if (pEl) pEl.textContent = Number(data.portfolio_users).toLocaleString();
          }
        })
        .catch(e => console.warn('Stats load failed', e));

      document.querySelectorAll('.search-tag').forEach(function(tag) {
        tag.addEventListener('click', function(e) {
          e.preventDefault();
          const q = e.target.getAttribute('data-q');
          const modal = document.getElementById('search-modal');
          const input = document.getElementById('search-input');
          if (modal && input) {
            modal.classList.add('search-modal--open');
            input.value = q;
            input.focus();
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        });
      });
    })();
  </script>
</BaseLayout>
