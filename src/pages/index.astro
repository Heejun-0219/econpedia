  <script is:inline>
    (function () {
      const form = document.getElementById('subscribe-form-new');
      if (!form) return;

      const emailInput = document.getElementById('subscribe-email-new');
      const btn = document.getElementById('subscribe-btn-new');
      const feedback = document.getElementById('subscribe-feedback-new');

      function showFeedback(message, isSuccess) {
        feedback.textContent = message;
        feedback.style.color = isSuccess ? 'var(--color-accent-primary)' : 'var(--color-accent-danger)';
        feedback.style.display = 'block';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        if (!email) return;

        btn.disabled = true;
        btn.textContent = '...';
        feedback.style.display = 'none';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();

          if (res.ok && data.success) {
            showFeedback(data.message || '구독 신청이 완료됐습니다.', true);
            emailInput.value = '';
            btn.textContent = '구독 완료';
          } else {
            showFeedback(data.error || '오류가 발생했습니다. 다시 시도해주세요.', false);
            btn.disabled = false;
            btn.textContent = '무료 구독';
          }
        } catch (err) {
          showFeedback('네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.', false);
          btn.disabled = false;
          btn.textContent = '무료 구독';
        }
      });
    })();
  </script>

  <script is:inline define:vars={{pastWeek, thisWeek, nextWeek}}>
    window.weatherTabsData = { pastWeek, thisWeek, nextWeek };
  </script>

  <script is:inline>
    (function () {
      const weatherContainer = document.getElementById('weather-week-container');
      const weatherTabs = document.querySelectorAll('.i7-top .actions .b');
      const weatherTitle = document.getElementById('weather-title');
      const weatherHeadline = document.getElementById('weather-headline');
      
      if (weatherContainer && weatherTabs.length === 3 && window.weatherTabsData) {
        weatherTabs.forEach((tab, idx) => {
          tab.addEventListener('click', () => {
            weatherTabs.forEach(t => t.classList.remove('on'));
            tab.classList.add('on');
            
            let data = [];
            if (idx === 0) {
              data = window.weatherTabsData.thisWeek;
              weatherTitle.textContent = "이번 주 경제 날씨";
              weatherHeadline.innerHTML = `이번 주 시장은 대체로 <b style="color:var(--color-accent-primary)">맑음</b>, 목요일 하루만 비 소식이에요.`;
            } else if (idx === 1) {
              data = window.weatherTabsData.pastWeek;
              weatherTitle.textContent = "지난 주 경제 날씨";
              weatherHeadline.innerHTML = `지난 주는 변동성이 큰 <b style="color:var(--color-accent-danger)">폭풍</b> 장세였어요.`;
            } else {
              data = window.weatherTabsData.nextWeek;
              weatherTitle.textContent = "다음 주 예보";
              weatherHeadline.innerHTML = `다음 주는 <b style="color:#ca8a04">흐림</b>. 주요 이벤트 발표가 예정되어 있어요.`;
            }
            
            weatherContainer.innerHTML = data.map(d => {
              const cssClass = d.cssClass || '';
              const evHtml = d.event ? `<div style="font-size:0.6rem; color:var(--color-accent-danger); margin-top:2px; font-weight:700; line-height:1.2; letter-spacing:-0.05em; word-break:keep-all;">${d.event}</div>` : '';
              return `
                <div class="i7-day ${cssClass}">
                  <div class="dow">${d.dow}</div>
                  <div class="dt">${d.dt}</div>
                  <div class="icon">${d.icon}</div>
                  <div class="lbl">${d.label}</div>
                  ${evHtml}
                </div>
              `;
            }).join('');
          });
        });
      }
    })();
  </script>

  <script is:inline>
    (function () {
      // stats fetch
      fetch('/api/stats')
        .then(res => res.json())
        .then(data => {
          if (data && data.total_visitors) {
            const subEl = document.getElementById('stat-subscribers');
            if (subEl) subEl.textContent = (14000 + data.total_visitors).toLocaleString();
          }
        })
        .catch(e => console.warn('Stats load failed', e));

      document.querySelectorAll('.search-tag').forEach(function(tag) {
        tag.addEventListener('click', function(e) {
          e.preventDefault();
          const q = e.target.getAttribute('data-q');
          const modal = document.getElementById('search-modal');
          const input = document.getElementById('search-input');
          if (modal && input) {
            modal.classList.add('search-modal--open');
            input.value = q;
            input.focus();
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        });
      });
    })();
  </script>
</BaseLayout>