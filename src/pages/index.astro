---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { icon: '🏦', title: '기초 경제학', desc: 'GDP, 인플레이션, 금리, 환율 등 경제의 기본 개념을 쉽게 배워보세요.', count: '24개 기사', href: '/economy/basics' },
  { icon: '📈', title: '투자 기초', desc: '주식, 채권, ETF, 부동산 등 투자의 첫 걸음을 시작하세요.', count: '18개 기사', href: '/economy/investment' },
  { icon: '💳', title: '생활 금융', desc: '신용점수, 대출, 보험, 세금 등 일상 속 금융 상식을 알려드립니다.', count: '21개 기사', href: '/economy/finance' },
  { icon: '🌍', title: '글로벌 경제', desc: '미국, 중국, 유럽 등 세계 경제의 흐름을 한눈에 파악하세요.', count: '15개 기사', href: '/economy/global' },
  { icon: '🏢', title: '기업 분석', desc: '재무제표 읽기, 산업 분석 등 기업을 보는 눈을 키워보세요.', count: '12개 기사', href: '/economy/corporate' },
  { icon: '📊', title: '경제 지표 해설', desc: 'CPI, PMI, 고용지표 등 경제 뉴스의 핵심 지표를 해설합니다.', count: '16개 기사', href: '/economy/indicators' },
  { icon: '🔥', title: '경제 트렌드', desc: 'AI 경제, ESG, 디지털 화폐 등 최신 경제 트렌드를 분석합니다.', count: '9개 기사', href: '/economy/trends' },
];

const featuredArticles = [
  {
    category: '기초 경제학',
    title: 'GDP란 무엇인가? — 국가 경제의 건강 검진표를 읽는 법',
    excerpt: 'GDP는 한 나라의 경제 크기를 나타내는 가장 기본적인 지표입니다. 우리나라의 GDP가 올랐다, 내렸다는 뉴스를 들을 때, 그것이 내 삶에 어떤 영향을 미치는지 알아보세요.',
    readingTime: '8분',
    date: '2026.04.01',
    href: '/economy/basics/what-is-gdp',
  },
  {
    category: '투자 기초',
    title: 'ETF 완전 정복 — 주식보다 안전하고, 적금보다 수익률 높은 투자법',
    excerpt: '"주식은 무서운데 적금 이자는 너무 낮아." 이런 고민을 가진 분들에게 ETF가 답이 될 수 있습니다. 초보자도 쉽게 시작할 수 있는 ETF 투자의 모든 것.',
    readingTime: '12분',
    date: '2026.04.01',
    href: '/economy/investment/etf-guide',
  },
  {
    category: '생활 금융',
    title: '신용점수 올리는 5가지 확실한 방법 — 은행이 절대 알려주지 않는 비밀',
    excerpt: '신용점수 1점 차이로 대출 금리가 달라집니다. 지금 당장 실천할 수 있는 신용점수 관리법을 전문가가 알려드립니다.',
    readingTime: '6분',
    date: '2026.04.01',
    href: '/economy/finance/credit-score-tips',
  },
];
---

<BaseLayout 
  title="경제 백과사전" 
  description="경제 초보자를 전문가로 만드는 경제 백과사전. GDP, 주식, ETF, 금리 등 복잡한 경제 개념을 쉽고 재밌게 배워보세요."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="hero__badge">📚 경제를 쉽게, 모두에게</span>
      <h1 class="hero__title">
        경제가 어렵다면,<br/>
        <span class="hero__title-gradient">EconPedia에서 시작하세요.</span>
      </h1>
      <p class="hero__subtitle">
        복잡한 경제 용어, 겁나는 투자 세계.<br/>
        초보자 눈높이에서 하나하나 풀어드립니다.
      </p>
      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-value">115+</div>
          <div class="hero__stat-label">경제 백과 기사</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">7</div>
          <div class="hero__stat-label">카테고리</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">5분+</div>
          <div class="hero__stat-label">평균 체류 시간</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="categories">
    <div class="container">
      <div class="section-header">
        <p class="section-label">카테고리</p>
        <h2 class="section-title">무엇을 배우고 싶으세요?</h2>
      </div>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="category-card" id={`category-${cat.title}`}>
            <div class="category-card__icon">{cat.icon}</div>
            <h3 class="category-card__title">{cat.title}</h3>
            <p class="category-card__desc">{cat.desc}</p>
            <span class="category-card__count">📄 {cat.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="articles">
    <div class="container">
      <div class="section-header">
        <p class="section-label">인기 기사</p>
        <h2 class="section-title">지금 가장 많이 읽히는 글</h2>
      </div>
      <div class="article-grid">
        {featuredArticles.map((article) => (
          <a href={article.href} class="article-card" id={`article-${article.title.slice(0, 10)}`}>
            <div class="article-card__body">
              <span class="article-card__category">{article.category}</span>
              <h3 class="article-card__title">{article.title}</h3>
              <p class="article-card__excerpt">{article.excerpt}</p>
              <div class="article-card__meta">
                <span class="article-card__reading-time">⏱ {article.readingTime} 읽기</span>
                <span>{article.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
