---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

import fs from 'fs';
import path from 'path';

// Load market data
let marketData = { weatherData: { weather: 'sunny', emoji: '☀️', label: '맑음', headline: '오늘은 평화로운 날이에요', color: '#34d399', walletImpacts: [] }, raw: {} };
try {
  const mdPath = path.resolve(process.cwd(), '.market-data.json');
  if (fs.existsSync(mdPath)) {
    marketData = JSON.parse(fs.readFileSync(mdPath, 'utf8'));
    if (!marketData.weatherData) marketData.weatherData = { weather: 'cloudy', emoji: '☁️', label: '흐림', headline: '위젯 데이터를 로딩중입니다...', color: '#94a3b8', walletImpacts: [] };
  }
} catch (e) {
  console.warn('Could not load .market-data.json', e.message);
}

const w = marketData.weatherData;

const impactIcons = {
  housing: 'home',
  travel: 'airplane',
  grocery: 'shopping-cart',
  gasoline: 'gas-pump',
  investment: 'chart-pie',
  crypto: 'currency-bitcoin',
  us_stock: 'flag-usa',
  calm: 'smile'
};

const getGuideLink = (category) => {
  const map = {
    housing: '/economy/finance',
    travel: '/economy/global',
    grocery: '/economy/finance',
    gasoline: '/economy/finance',
    investment: '/economy/investment',
    crypto: '/economy/investment',
    us_stock: '/economy/global'
  };
  return map[category] || '/economy/basics';
};
---

<BaseLayout
  title="내 지갑 대시보드"
  description="오늘의 거시경제 변화가 내 생활비에 미치는 영향을 확인하세요."
>
  <div class="container" style="padding-top: 40px; padding-bottom: 80px;">
    
    <!-- 로딩 스플래시 -->
    <div id="wallet-loading" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 50vh; color: var(--color-text-muted);">
      <Icon name="clock" size={48} style="animation: spin 2s linear infinite; opacity: 0.5; margin-bottom: 16px;" />
      <p style="font-weight: 600;">안전하게 계정을 확인하고 있습니다...</p>
    </div>

    <!-- 비로그인 뷰 (Toss Style Splash) -->
    <div id="wallet-unauth-view" style="display: none; text-align: center; max-width: 500px; margin: 60px auto;">
      <div style="background: var(--color-bg-secondary); width: 80px; height: 80px; border-radius: 40px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
        <Icon name="briefcase" size={40} style="color: var(--color-accent-primary);" />
      </div>
      <h1 style="font-size: 32px; font-weight: 800; margin-bottom: 16px; line-height: 1.3; color: var(--color-text-primary);">내 지갑,<br/>매일 얼마나 새고 있을까요?</h1>
      <p style="font-size: 16px; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 40px;">
        복잡한 경제 뉴스 대신,<br/>내 대출 이자와 주식 타격감을 매일 아침 계산해 드립니다.
      </p>
      
      <button id="btn-google-login" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px; background: #ffffff; color: #111; border: 1px solid #e5e7eb; padding: 16px; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; box-shadow: var(--shadow-card); transition: all 0.2s;">
        <svg viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Google로 3초 만에 시작하기
      </button>
      <button id="btn-demo-login" style="margin-top: 24px; background: transparent; border: none; color: var(--color-text-muted); font-size: 14px; text-decoration: underline; cursor: pointer;">로그인 없이 샘플 보기</button>
    </div>

    <!-- 로그인 뷰 (Dashboard) -->
    <div id="wallet-auth-view" style="display: none;">
      
      <!-- 상단 프로필 및 헤더 -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <img id="user-avatar" src="" style="width: 48px; height: 48px; border-radius: 24px; border: 1px solid var(--color-border); background: var(--color-bg-secondary); object-fit: cover;" />
          <div>
            <h1 style="font-size: 22px; font-weight: 800; margin: 0;"><span id="user-name">게스트</span>님의 지갑 타격감</h1>
            <p style="margin: 4px 0 0 0; font-size: 14px; color: var(--color-text-muted);">오늘 하루, 내 자산에 일어난 변화예요.</p>
          </div>
        </div>
        <button id="btn-logout" style="background: transparent; border: 1px solid var(--color-border); padding: 8px 16px; border-radius: 12px; font-size: 13px; font-weight: 600; color: var(--color-text-muted); cursor: pointer;">로그아웃</button>
      </div>

      <!-- Weather summary card -->
      <div class="wallet-summary" style={`background: radial-gradient(circle at top right, ${w.color}15, transparent); border: 1px solid ${w.color}30; border-radius: 24px; padding: 32px; margin-bottom: 40px; text-align: center;`}>
        <div style={`display: inline-flex; align-items: center; gap: 6px; color: ${w.color}; background: ${w.color}18; border: 1px solid ${w.color}35; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600; margin-bottom: 20px;`}>
          <Icon name="econ-weather" size={14} />
          오늘의 거시경제 날씨
        </div>
        <div style={`display: flex; justify-content: center; color: ${w.color}; margin-bottom: 16px;`}>
          <Icon name={`weather-${w.weather}`} size={64} />
        </div>
        <h2 style="font-size: 28px; font-weight: 700; margin-bottom: 8px;">{w.label}</h2>
        <p style="font-size: 20px; color: var(--color-text-primary);">{w.headline}</p>
      </div>

      <!-- Detail Grid -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; border-bottom: 1px solid var(--color-border); padding-bottom: 16px;">
        <h2 style="font-size: 20px; font-weight: 700; margin: 0; color: var(--color-text-primary);">종목별 타격감</h2>
        <button id="open-wallet-settings" style="display: flex; align-items: center; gap: 6px; padding: 8px 16px; background: var(--color-bg-secondary); color: var(--color-text-primary); border: 1px solid var(--color-border); border-radius: 12px; font-weight: 600; font-size: 13px; cursor: pointer; transition: background 0.2s;">
          <Icon name="settings" size={14} /> 내 자산 입력하기
        </button>
      </div>
      
      <div class="wallet-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 64px;">
        {w.walletImpacts && w.walletImpacts.length > 0 ? (
          w.walletImpacts.map((im) => (
            <div class="wallet-card" style="background: var(--color-bg-primary); border: 1px solid var(--color-border); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 16px; box-shadow: var(--shadow-card); transition: transform 0.2s;">
              <div class="wallet-card__header" style="display: flex; align-items: flex-start; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 12px;">
                  <span style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 12px; background: var(--color-bg-secondary); color: var(--color-text-primary);">
                    <Icon name={impactIcons[im.category] || 'document'} size={20} />
                  </span>
                  <span style="font-size: 16px; font-weight: 700; color: var(--color-text-primary);" set:html={im.label.replace('·', '<br/>')}></span>
                </div>
                <div class="wallet-card__badge" style={`padding: 4px 10px; border-radius: 8px; font-size: 12px; font-weight: 700; background: ${im.sentiment === 'positive' ? 'var(--color-accent-primary)' : im.sentiment === 'negative' ? 'var(--color-accent-danger)' : 'var(--color-bg-secondary)'}; color: ${im.sentiment === 'calm' ? 'var(--color-text-muted)' : '#fff'};`}>
                  {im.sentiment === 'positive' ? '긍정적' : im.sentiment === 'negative' ? '부정적' : '평안함'}
                </div>
              </div>
              
              <div class="wallet-card__body">
                <div class="wallet-card__value" style={`font-size: 22px; font-weight: 800; line-height: 1.3; color: ${im.sentiment === 'positive' ? 'var(--color-accent-primary)' : im.sentiment === 'negative' ? 'var(--color-accent-danger)' : 'var(--color-text-primary)'};`}>
                  {im.message.split(' (')[0]}
                </div>
                {im.message.includes('(') && (
                  <div class="wallet-card__note" style="margin-top: 6px; font-size: 13px; color: var(--color-text-muted);">
                    {im.message.substring(im.message.indexOf('('))}
                  </div>
                )}
              </div>

              {im.category !== 'calm' && (
                <div class="wallet-card__action" style="margin-top: auto; padding-top: 16px; border-top: 1px solid var(--color-border);">
                  <a href={getGuideLink(im.category)} style="text-decoration: none; width: 100%; display: flex; align-items: center; justify-content: space-between; color: var(--color-text-secondary); font-weight: 600; font-size: 14px;">
                    대응 가이드 보기 
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>
              )}
            </div>
          ))
        ) : (
          <div style="grid-column: 1 / -1; padding: 48px; text-align: center; color: var(--color-text-muted); background: var(--color-bg-secondary); border-radius: 16px; border: 1px solid var(--color-border);">
            데이터를 불러오지 못했습니다. 잠시 후 다시 시도해주세요.
          </div>
        )}
      </div>

    </div>

    <!-- Personalization Modal (Toss Style Bottom Sheet) -->
    <div id="settings-modal" style="display: none; position: fixed; inset: 0; z-index: 9999; align-items: flex-end; justify-content: center; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
      <div class="bottom-sheet" style="background: var(--color-bg-primary); width: 100%; max-width: 600px; border-radius: 24px 24px 0 0; padding: 32px 24px 48px; box-shadow: 0 -8px 32px rgba(0,0,0,0.1); max-height: 85vh; overflow-y: auto;">
        <div style="width: 40px; height: 4px; background: var(--color-border-strong); border-radius: 2px; margin: 0 auto 24px;"></div>
        <h3 style="font-size: 22px; font-weight: 800; margin-bottom: 8px; color: var(--color-text-primary);">내 자산 입력하기</h3>
        <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: 24px;">입력된 정보는 오직 브라우저와 안전한 개인 계정에만 저장되며, 타격감 계산 용도로만 쓰입니다.</p>
        
        <form id="settings-form" style="display: flex; flex-direction: column; gap: 20px;">
          <div>
            <label class="wallet-label">주담대/전세대출 원금 (원)</label>
            <input type="text" inputmode="numeric" id="input-housing" placeholder="예: 300,000,000" class="wallet-input" />
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <label class="wallet-label">월 식료품비 (원)</label>
              <input type="text" inputmode="numeric" id="input-grocery" placeholder="예: 800,000" class="wallet-input" />
            </div>
            <div>
              <label class="wallet-label">1회 주유비 (원)</label>
              <input type="text" inputmode="numeric" id="input-gasoline" placeholder="예: 50,000" class="wallet-input" />
            </div>
          </div>
          <div>
            <label class="wallet-label">국내 주식 투자금 (원)</label>
            <input type="text" inputmode="numeric" id="input-investment" placeholder="예: 10,000,000" class="wallet-input" />
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <label class="wallet-label">미국 주식/ETF (원)</label>
              <input type="text" inputmode="numeric" id="input-us_stock" placeholder="예: 5,000,000" class="wallet-input" />
            </div>
            <div>
              <label class="wallet-label">비트코인 (원)</label>
              <input type="text" inputmode="numeric" id="input-crypto" placeholder="예: 1,000,000" class="wallet-input" />
            </div>
          </div>
          <div>
            <label class="wallet-label">해외여행/직구 예산 (원)</label>
            <input type="text" inputmode="numeric" id="input-travel" placeholder="예: 1,000,000" class="wallet-input" />
          </div>
          
          <div style="display: flex; gap: 12px; margin-top: 24px;">
            <button type="button" id="close-wallet-settings" style="flex: 1; padding: 16px; background: var(--color-bg-secondary); border: none; border-radius: 16px; color: var(--color-text-primary); font-weight: 700; font-size: 15px; cursor: pointer;">닫기</button>
            <button type="submit" style="flex: 2; padding: 16px; background: var(--color-accent-primary); border: none; border-radius: 16px; color: white; font-weight: 700; font-size: 15px; cursor: pointer;">저장하고 확인하기</button>
          </div>
        </form>
      </div>
    </div>
    
    <script id="market-raw-data" type="application/json" set:html={JSON.stringify(marketData.raw || {})}></script>
    <script>
      import { supabase } from '../lib/supabase.js';

      document.addEventListener('DOMContentLoaded', async () => {
        const rawDataEl = document.getElementById('market-raw-data');
        if (!rawDataEl) return;
        const raw = JSON.parse(rawDataEl.textContent);
        
        const DEFAULTS = {
          housing: 300000000,
          grocery: 800000,
          gasoline: 50000,
          investment: 10000000,
          us_stock: 5000000,
          crypto: 1000000,
          travel: 1000000
        };

        let settings = { ...DEFAULTS };
        let currentUser = null;

        // Views
        const loadingView = document.getElementById('wallet-loading');
        const unauthView = document.getElementById('wallet-unauth-view');
        const authView = document.getElementById('wallet-auth-view');

        // Profile elements
        const userNameEl = document.getElementById('user-name');
        const userAvatarEl = document.getElementById('user-avatar');

        // Check Auth
        try {
          const { data: { session } } = await supabase.auth.getSession();
          if (session) {
            currentUser = session.user;
            showAuthView(currentUser);
            await loadSettings(currentUser.id);
          } else {
            showUnauthView();
          }
        } catch(err) {
          console.error("Auth check failed", err);
          showUnauthView();
        }

        // Google Login Action
        document.getElementById('btn-google-login')?.addEventListener('click', async () => {
          await supabase.auth.signInWithOAuth({ 
            provider: 'google', 
            options: { redirectTo: window.location.origin + '/wallet' } 
          });
        });

        // Demo Login Action (Skip Auth)
        document.getElementById('btn-demo-login')?.addEventListener('click', () => {
          currentUser = null; // Guest mode
          showAuthView(null);
          loadSettings(null); // Load local storage
        });

        // Logout
        document.getElementById('btn-logout')?.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.reload();
        });

        function showAuthView(user) {
          loadingView.style.display = 'none';
          unauthView.style.display = 'none';
          authView.style.display = 'block';

          if (user) {
            userNameEl.textContent = user.user_metadata?.full_name || '회원';
            userAvatarEl.src = user.user_metadata?.avatar_url || 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="%23ddd"><circle cx="24" cy="24" r="24"/></svg>';
            document.getElementById('btn-logout').style.display = 'block';
          } else {
            userNameEl.textContent = '게스트';
            userAvatarEl.src = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="%23ddd"><circle cx="24" cy="24" r="24"/></svg>';
            document.getElementById('btn-logout').style.display = 'none'; // 게스트 모드면 로그아웃 숨김
          }
        }

        function showUnauthView() {
          loadingView.style.display = 'none';
          unauthView.style.display = 'block';
          authView.style.display = 'none';
        }

        async function loadSettings(userId) {
          if (userId) {
            const { data, error } = await supabase
              .from('user_settings')
              .select('*')
              .eq('user_id', userId)
              .single();
            
            if (data && !error) {
              const dbSettings = { ...data };
              delete dbSettings.id;
              delete dbSettings.user_id;
              delete dbSettings.created_at;
              settings = { ...DEFAULTS, ...dbSettings };
            } else {
              const saved = localStorage.getItem('econpedia_wallet_settings');
              if (saved) {
                settings = { ...DEFAULTS, ...JSON.parse(saved) };
                await supabase.from('user_settings').upsert({ user_id: userId, ...settings });
              }
            }
          } else {
            const saved = localStorage.getItem('econpedia_wallet_settings');
            if (saved) settings = { ...DEFAULTS, ...JSON.parse(saved) };
          }
          recalculate();
        }

        // Modals logic
        const modal = document.getElementById('settings-modal');
        const openBtn = document.getElementById('open-wallet-settings');
        const closeBtn = document.getElementById('close-wallet-settings');
        const form = document.getElementById('settings-form');

        // 천 단위 콤마 포맷터
        const formatNumberWithCommas = (num) => {
          if (num === '' || num === null || num === undefined) return '';
          const numeric = num.toString().replace(/[^0-9]/g, '');
          if (numeric === '') return '';
          return Number(numeric).toLocaleString();
        };

        const parseNumberFromCommas = (str) => {
          if (!str) return 0;
          return Number(str.replace(/,/g, ''));
        };

        // 입력 폼에 콤마 적용
        Object.keys(DEFAULTS).forEach(key => {
          const input = document.getElementById('input-' + key);
          if (input) {
            input.addEventListener('input', (e) => {
              const cursorPosition = e.target.selectionStart;
              const originalLength = e.target.value.length;
              const formatted = formatNumberWithCommas(e.target.value);
              e.target.value = formatted;
              const diff = formatted.length - originalLength;
              const newCursor = Math.max(0, cursorPosition + diff);
              e.target.setSelectionRange(newCursor, newCursor);
            });
          }
        });

        if(openBtn) {
          openBtn.addEventListener('click', () => {
            Object.keys(DEFAULTS).forEach(key => {
              const input = document.getElementById('input-' + key);
              if (input) input.value = formatNumberWithCommas(settings[key]);
            });
            // Bottom sheet animation effect
            modal.style.display = 'flex';
            const sheet = modal.querySelector('.bottom-sheet');
            sheet.animate([{transform: 'translateY(100%)'}, {transform: 'translateY(0)'}], {duration: 300, easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)'});
          });
        }

        if(closeBtn) {
          closeBtn.addEventListener('click', () => {
            const sheet = modal.querySelector('.bottom-sheet');
            const anim = sheet.animate([{transform: 'translateY(0)'}, {transform: 'translateY(100%)'}], {duration: 250, easing: 'ease-in'});
            anim.onfinish = () => modal.style.display = 'none';
          });
        }

        if(form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            Object.keys(DEFAULTS).forEach(key => {
              const input = document.getElementById('input-' + key);
              if (input) {
                const parsed = parseNumberFromCommas(input.value);
                settings[key] = parsed === 0 ? DEFAULTS[key] : parsed;
              }
            });

            if (currentUser) {
              try {
                await supabase.from('user_settings').upsert({ user_id: currentUser.id, ...settings });
              } catch (err) {
                console.error('DB 저장 실패:', err);
                localStorage.setItem('econpedia_wallet_settings', JSON.stringify(settings));
              }
            } else {
              localStorage.setItem('econpedia_wallet_settings', JSON.stringify(settings));
            }
            
            const sheet = modal.querySelector('.bottom-sheet');
            const anim = sheet.animate([{transform: 'translateY(0)'}, {transform: 'translateY(100%)'}], {duration: 250, easing: 'ease-in'});
            anim.onfinish = () => {
              modal.style.display = 'none';
              recalculate();
            };
          });
        }

        const formatChange = (change, upText, downText) => {
          if (change === 0) return '변동 없어요 😌';
          return change > 0 ? upText : downText;
        };

        // Recalculation logic
        const recalculate = () => {
          if (raw.baseRate) {
            const change = Math.round((settings.housing * (raw.baseRate.change / 100)) / 12);
            updateCard('housing', `내 대출금 기준 이번 달 이자가 약 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '늘었어요', '줄었어요')}`, change);
          }
          if (raw.cpi) {
            const change = Math.round(settings.grocery * (raw.cpi.changePercent / 100));
            updateCard('grocery', `내 식비 체감 물가가 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '올랐어요', '내렸어요')}`, change);
          }
          if (raw.oil) {
            const change = Math.round(settings.gasoline * (raw.oil.changePercent / 100) * 0.5);
            updateCard('gasoline', `1회 주유 시 약 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '올랐어요', '내렸어요')}`, change);
          }
          if (raw.kospi) {
            const change = Math.round(settings.investment * (raw.kospi.changePercent / 100));
            updateCard('investment', `내 투자금 기준 약 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '올랐어요', '빠졌어요')}`, change);
          }
          if (raw.sp500 && raw.krw) {
            const change = Math.round(settings.us_stock * ((raw.sp500.changePercent + raw.krw.changePercent) / 100));
            updateCard('us_stock', `내 투자금 기준 약 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '올랐어요', '빠졌어요')}`, change);
          }
          if (raw.krw) {
            const change = Math.round(settings.travel * (raw.krw.changePercent / 100));
            updateCard('travel', `환전 시 ${Math.abs(change).toLocaleString()}원 더 ${formatChange(change, '비싸졌어요', '아꼈어요')}`, change);
          }
          if (raw.bitcoin) {
            const change = Math.round(settings.crypto * (raw.bitcoin.changePercent / 100));
            updateCard('crypto', `내 투자금 기준 약 ${Math.abs(change).toLocaleString()}원 ${formatChange(change, '올랐어요', '빠졌어요')}`, change);
          }
        };

        const updateCard = (category, newMessage, changeValue) => {
          const cards = document.querySelectorAll('.wallet-card');
          cards.forEach(card => {
            const badgeLabel = card.querySelector('.wallet-card__header span:nth-child(2)');
            if (!badgeLabel) return;
            const text = badgeLabel.textContent.trim();
            const map = {
              'housing': '주거비',
              'grocery': '장바구니',
              'gasoline': '주유비',
              'investment': '국내 주식',
              'us_stock': '미국 주식',
              'crypto': '비트코인',
              'travel': '해외여행',
            };
            
            if (text.includes(map[category])) {
              const valEl = card.querySelector('.wallet-card__value');
              const badgeEl = card.querySelector('.wallet-card__badge');
              
              if (valEl) {
                let color = 'var(--color-text-primary)';
                let sentimentText = '평안함';
                let bg = 'var(--color-bg-secondary)';
                
                if (category === 'housing' || category === 'grocery' || category === 'gasoline' || category === 'travel') {
                  if (changeValue > 0) { color = 'var(--color-accent-danger)'; sentimentText = '부정적'; bg = 'rgba(239,68,68,0.1)'; }
                  else if (changeValue < 0) { color = 'var(--color-accent-primary)'; sentimentText = '긍정적'; bg = 'rgba(16,185,129,0.1)'; }
                } else {
                  if (changeValue > 0) { color = 'var(--color-accent-primary)'; sentimentText = '긍정적'; bg = 'rgba(16,185,129,0.1)'; }
                  else if (changeValue < 0) { color = 'var(--color-accent-danger)'; sentimentText = '부정적'; bg = 'rgba(239,68,68,0.1)'; }
                }

                valEl.style.opacity = '0';
                setTimeout(() => {
                  valEl.textContent = newMessage;
                  valEl.style.color = color;
                  if (badgeEl) {
                    badgeEl.textContent = sentimentText;
                    badgeEl.style.color = color;
                    badgeEl.style.background = bg;
                  }
                  valEl.style.opacity = '1';
                }, 150);
              }
            }
          });
        };

      });
    </script>
  </div>
</BaseLayout>

<style>
  @keyframes spin { 100% { transform: rotate(360deg); } }
  .wallet-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-primary-alpha);
  }
  .wallet-label {
    display: block; font-size: 13px; font-weight: 700; color: var(--color-text-secondary); margin-bottom: 8px;
  }
  .wallet-input {
    width: 100%; padding: 14px 16px; border-radius: 12px; border: 1px solid var(--color-border); background: var(--color-bg-primary); color: var(--color-text-primary); font-size: 16px; font-weight: 600;
  }
  .wallet-input:focus {
    outline: none; border-color: var(--color-accent-primary); box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
</style>