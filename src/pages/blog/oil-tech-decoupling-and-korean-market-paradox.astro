const date = "2026-04-20";
const description = "유가 폭락에도 나스닥만 오르는 디커플링 현상과 고환율 호재에도 하락하는 한국 코스피의 역설을 분석하고 2030 직장인을 위한 자산 전략을 제시합니다.";
const tags = ["거시경제","투자전략","자산배분","나스닥","코스피","환율","유가폭락","PMI"];
---

<BaseLayout title={title} description={description} article={true}>
