const date = "2026-04-04";
const description = "오늘 코스피가 2.74% 급등한 이유를 글로벌 무역 정책 변화에서 찾아봅니다. 이코노와 함께 무역 정책이 우리 경제와 투자에 어떤 의미를 가지는지 쉽게 분석해 보세요.";
const tags = ["코스피","주식시장","무역정책","글로벌경제","한국경제","투자전략","이코노","관세","미중무역"];
---

