const date = "2026-04-08";
const description = "2026년 4월 8일 코스피 6%대 급등과 원화 강세의 배경을 분석합니다. 관세 갈등 해소 기대감이 한국 경제와 개인 자산에 미칠 영향을 이코노가 쉽게 설명해 드려요.";
const tags = ["코스피","관세갈등","외국인투자","수출경제","환율","주식시장","경제분석","이코노"];
---

