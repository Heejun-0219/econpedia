---
// EconPedia 브랜드 SVG 아이콘 시스템
// 로고와 동일한 스타일 — 24x24, geometric, currentColor
export interface Props {
  name: string;
  class?: string;
  size?: number;
}
const { name, class: className = '', size = 24 } = Astro.props;

const icons: Record<string, string> = {

  // 기초 경제학 — 오픈 북
  'book': `
    <path d="M2 4h9a1 1 0 011 1v15H3a1 1 0 01-1-1V4z" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
    <path d="M22 4h-9a1 1 0 00-1 1v15h10a1 1 0 001-1V4z" fill="currentColor" opacity="0.3" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
    <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="1.25" opacity="0.4"/>
    <line x1="5" y1="8.5" x2="9" y2="8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
    <line x1="5" y1="12" x2="9" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
    <line x1="5" y1="15.5" x2="7.5" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>`,

  // 투자 기초 — 라인 차트
  'chart-line': `
    <line x1="3" y1="20" x2="3" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
    <line x1="3" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
    <polyline points="5,17 9,11 13,14 19,6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <circle cx="5" cy="17" r="1.5" fill="currentColor"/>
    <circle cx="9" cy="11" r="1.5" fill="currentColor"/>
    <circle cx="13" cy="14" r="1.5" fill="currentColor"/>
    <circle cx="19" cy="6" r="1.5" fill="currentColor"/>`,

  // 생활 금융 — 지갑
  'wallet': `
    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <path d="M2 11h20" stroke="currentColor" stroke-width="1.5" opacity="0.35"/>
    <path d="M7 4l1.5-1h7L17 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5"/>
    <rect x="14.5" y="13.5" width="5" height="4" rx="1" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.25"/>
    <circle cx="17" cy="15.5" r="1" fill="currentColor" opacity="0.7"/>`,

  // 글로벌 경제 — 지구본
  'globe': `
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <path d="M3 12h18" stroke="currentColor" stroke-width="1.25" opacity="0.45"/>
    <path d="M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9" stroke="currentColor" stroke-width="1.25" fill="none" opacity="0.45"/>
    <path d="M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9" stroke="currentColor" stroke-width="1.25" fill="none" opacity="0.45"/>
    <path d="M5.5 7.5c1.7 1 3.9 1.5 6.5 1.5s4.8-.5 6.5-1.5" stroke="currentColor" stroke-width="1.25" fill="none" opacity="0.45"/>
    <path d="M5.5 16.5c1.7-1 3.9-1.5 6.5-1.5s4.8.5 6.5 1.5" stroke="currentColor" stroke-width="1.25" fill="none" opacity="0.45"/>`,

  // 기업 분석 — 빌딩
  'building': `
    <rect x="2" y="9" width="10" height="13" rx="1" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <rect x="12" y="4" width="10" height="18" rx="1" fill="currentColor" opacity="0.12" stroke="currentColor" stroke-width="1.75"/>
    <rect x="5" y="12" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="9" y="12" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="15" y="7" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="19" y="7" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="15" y="12" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="19" y="12" width="2" height="2" rx="0.4" fill="currentColor" opacity="0.55"/>
    <rect x="7" y="18" width="2" height="4" rx="0.4" fill="currentColor" opacity="0.4"/>
    <rect x="16" y="18" width="3" height="4" rx="0.4" fill="currentColor" opacity="0.4"/>`,

  // 경제 지표 — 계기판
  'gauge': `
    <path d="M5 17a8 8 0 1114 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
    <line x1="12" y1="9" x2="12" y2="10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="7.3" y1="10.7" x2="8.3" y2="11.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="16.7" y1="10.7" x2="15.7" y2="11.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="5" y1="17" x2="6.5" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="17.5" y1="17" x2="19" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="12" y1="17" x2="16.5" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <circle cx="12" cy="17" r="1.75" fill="currentColor"/>`,

  // 경제 트렌드 — 스파크라인
  'trend': `
    <polyline points="2,17 5.5,13 8.5,15.5 12,7 15,11.5 18,5 22,8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <circle cx="18" cy="5" r="2.75" fill="currentColor" opacity="0.18"/>
    <circle cx="18" cy="5" r="1.5" fill="currentColor"/>`,

  // 로봇/AI — 데일리 브리핑 작성자
  'robot': `
    <rect x="7" y="9" width="10" height="9" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <rect x="9" y="12" width="2" height="2" rx="0.5" fill="currentColor" opacity="0.7"/>
    <rect x="13" y="12" width="2" height="2" rx="0.5" fill="currentColor" opacity="0.7"/>
    <path d="M10 16.5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
    <path d="M12 9V7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    <circle cx="12" cy="6" r="1.25" fill="currentColor"/>
    <path d="M7 13H5m12 0h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>`,

  // 문서 — 기사 수
  'document': `
    <rect x="4" y="2" width="12" height="16" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <rect x="8" y="6" width="16" height="16" rx="2" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="1.75"/>
    <line x1="11" y1="10" x2="20" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
    <line x1="11" y1="13.5" x2="20" y2="13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
    <line x1="11" y1="17" x2="16" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>`,

  // 뉴스레터/전체보기 — 라이브러리
  'library': `
    <rect x="2" y="4" width="5" height="16" rx="1" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.75"/>
    <rect x="9.5" y="7" width="5" height="13" rx="1" fill="currentColor" opacity="0.3" stroke="currentColor" stroke-width="1.75"/>
    <rect x="17" y="2" width="5" height="18" rx="1" fill="currentColor" opacity="0.5" stroke="currentColor" stroke-width="1.75"/>`,
};
---

<svg
  class={`econ-icon ${className}`}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  aria-hidden="true"
  set:html={icons[name] ?? ''}
/>
