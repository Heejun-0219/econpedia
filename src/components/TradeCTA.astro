---
export interface Props {
  ticker: string;
  name: string;
  price?: string;
  change?: string;
  isPositive?: boolean;
  isin?: string;
}

const { ticker, name, price = "₩85,300", change = "▲ 1.2%", isPositive = true, isin: isinProp } = Astro.props;

// 데이터에서 넘어온 isin 우선 사용, 없으면 티커를 폴백으로 사용
const isin = isinProp || ticker;
---

<div class="trade-cta-widget">
  <div class="trade-cta__header">
    <div class="trade-cta__info">
      <span class="trade-cta__name">{name}</span>
      <span class="trade-cta__ticker">{ticker}</span>
    </div>
    <div class="trade-cta__price-block">
      <span class="trade-cta__price">{price}</span>
      <span class={isPositive ? 'trade-cta__change positive' : 'trade-cta__change negative'}>{change}</span>
    </div>
  </div>
  
  <div class="trade-cta__actions">
    <button 
      class="trade-cta__btn trade-cta__btn--primary" 
      data-trade-buy-btn 
      data-ticker={ticker} 
      data-isin={isin}
    >
      토스증권에서 바로 구매하기
    </button>
    <button class="trade-cta__btn trade-cta__btn--secondary" data-trade-watchlist-btn data-name={name} data-ticker={ticker}>관심 종목에 담기 ♡</button>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  document.addEventListener('DOMContentLoaded', () => {
    // 1. 매수 버튼 클릭 처리 (PC/Mobile 분기)
    const buyButtons = document.querySelectorAll('[data-trade-buy-btn]');
    buyButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const ticker = target.getAttribute('data-ticker') || '';
        const isin = target.getAttribute('data-isin') || '';
        
        // PC/Mobile 판단
        const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
        
        if (isMobile) {
          // 모바일: 앱 딥링크 (supertoss://stock/item?code=ISIN)
          const deepLink = `supertoss://stock/item?code=${isin}`;
          window.location.href = deepLink;
          
          // 앱 미설치 시 유니버설 링크로 폴백 (1.5초 후)
          setTimeout(() => {
            window.location.href = `https://toss.im/stock/item?code=${isin}`;
          }, 1500);
        } else {
          // PC: 웹 트레이딩 뷰 주문 화면 (https://www.tossinvest.com/stocks/[ISIN]/order)
          // ISIN이 없는 경우 티커 기반 기본 페이지로 이동
          const webUrl = (isin && (isin.startsWith('US') || isin.startsWith('KR')))
            ? `https://www.tossinvest.com/stocks/${isin}/order`
            : `https://www.tossinvest.com/stocks/${ticker}`;
          window.open(webUrl, '_blank');
        }
      });
    });

    // 2. 관심종목 버튼 클릭 처리
    const watchlistButtons = document.querySelectorAll('[data-trade-watchlist-btn]');
    watchlistButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) {
          alert('관심 종목에 담으려면 로그인이 필요합니다. 먼저 로그인해주세요.');
          const loginBtn = document.getElementById('auth-login-btn');
          if (loginBtn) loginBtn.click();
          return;
        }
        
        const name = e.currentTarget.getAttribute('data-name');
        alert(`${name} 종목이 관심 목록에 추가되었습니다!`);
      });
    });
  });
</script>

<style>
.trade-cta-widget {
  margin-top: 3rem;
  padding: 1.5rem;
  border-radius: 16px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.trade-cta__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.trade-cta__info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.trade-cta__name {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-text-primary);
}

.trade-cta__ticker {
  font-size: 0.9rem;
  color: var(--color-text-muted);
}

.trade-cta__price-block {
  text-align: right;
}

.trade-cta__price {
  display: block;
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--color-text-primary);
}

.trade-cta__change {
  font-size: 0.9rem;
  font-weight: 600;
}

.trade-cta__change.positive { color: #f04452; } 
.trade-cta__change.negative { color: #3182f6; } 

.trade-cta__actions {
  display: flex;
  gap: 10px;
}

.trade-cta__btn {
  flex: 1;
  padding: 14px 16px;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
}

.trade-cta__btn--primary {
  background: #3182f6; 
  color: white;
}

.trade-cta__btn--primary:hover {
  background: #1b64da;
}

.trade-cta__btn--secondary {
  background: var(--color-bg-primary);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
}

.trade-cta__btn--secondary:hover {
  background: var(--color-bg-card-hover);
}

@media (max-width: 600px) {
  .trade-cta__actions {
    flex-direction: column;
  }
}
</style>
